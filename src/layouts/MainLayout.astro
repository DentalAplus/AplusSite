              "@type": "Service",
              "name": "Alman Medentika İmplant"
            },
            "price": "14000",
            "priceCurrency": "TRY"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Nobel Biocare İmplant"
            },
            "price": "30750",
            "priceCurrency": "TRY"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Straumann İmplant"
            },
            "price": "40000",
            "priceCurrency": "TRY"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "All On Four İmplant Tedavisi"
            },
            "price": "95000",
            "priceCurrency": "TRY"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Zirkonyum Tek Diş Kaplama"
            },
            "price": "6600",
            "priceCurrency": "TRY"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Muayene, Röngten ve 3D Tomografi"
            },
            "price": "0",
            "priceCurrency": "TRY"
          }
        ]
      }
    }
    </script>

