      "@id": "https://www.dentalimplanttrakya.com",
      "url": "https://www.dentalimplanttrakya.com",
      "telephone": "+902124000013",
      "email": "bilgi@dentalimplanttrakya.com",
      "isAcceptingNewPatients": true,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Piri Mehmet Paşa Mah. Yemenciler Sok No:13B",
        "addressLocality": "Silivri",
        "addressRegion": "İstanbul",
        "postalCode": "34570",
        "addressCountry": "TR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 41.0735,
        "longitude": 28.2468
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.7",
        "reviewCount": "625",
        "bestRating": "5",
        "worstRating": "1"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday"
        ],
        "opens": "09:00",
        "closes": "19:00"
      },
      "priceRange": "$$",
      "paymentAccepted": "Cash, Credit Card, Bank Transfer",
      "currenciesAccepted": "TRY, EUR, USD, GBP",
      "medicalSpecialty": [
        "Oral and Maxillofacial Surgery",
        "Prosthodontics",
        "Periodontics",
        "Orthodontics",
        "Endodontics",
        "Pediatric Dentistry",
        "Cosmetic Dentistry"
      ],
      "availableService": [
        {
          "@type": "MedicalProcedure",
          "name": "Ücretsiz İlk Muayene, Röngten ve 3D Tomografi",
          "description": "Kliniğimizde uzman hekimlerimiz tarafından yapılan detaylı ağız içi muayene, panoramik röntgen ve 3D Dental Tomografi (Volumetrik Tomografi) analizleri tamamen ücretsizdir."
        },
        {
          "@type": "MedicalProcedure",
          "name": "İmplant Tedavisi (Dünya Markaları)",
          "description": "Uzman Çene Cerrahları tarafından uygulanan; Straumann, Nobel Biocare, Bego, Medentika ve Medigma gibi ömür boyu garantili, %100 orijinal sertifikalı implant uygulamaları."
        },
        {
          "@type": "MedicalProcedure",
          "name": "Zirkonyum ve Porselen Diş Kaplama",
          "description": "Uzman Protez hekimlerimiz (Protetik Diş Tedavisi Uzmanı) tarafından dijital ölçü (CAD/CAM) ile tasarlanan estetik, doğal ve yüksek ışık geçirgenliğine sahip diş kaplamaları."
        },
        {
          "@type": "MedicalProcedure",
          "name": "Dijital Gülüş Tasarımı (Hollywood Smile)",
          "description": "Kişinin yüz hatlarına, dudak yapısına ve altın orana uygun olarak porselen lamina (yaprak diş) ve zirkonyum kullanılarak tasarlanan kusursuz gülüş estetiği."
        },
        {
          "@type": "MedicalProcedure",
          "name": "All-on-4 ve All-on-6 İmplant Cerrahisi",
          "description": "Tam dişsizlik durumlarında ileri cerrahi tekniklerle aynı gün içinde sabit protez dişlere kavuşmanızı sağlayan A Plus implant konsepti."
        },
        {
          "@type": "MedicalProcedure",
          "name": "Ortodonti ve Şeffaf Plak Tedavisi",
          "description": "Uzman Ortodontistler eşliğinde her yaşa uygun telsiz ortodonti (şeffaf plaklar) ve estetik porselen/metal diş teli tedavileri."
        },
        {
          "@type": "MedicalProcedure",
          "name": "Çene Cerrahisi ve 20'lik Diş Çekimi",
          "description": "Uzman Çene Cerrahları tarafından ağrısız ve konforlu bir şekilde gerçekleştirilen gömülü yirmilik diş çekimleri ve kist operasyonları."
        }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Diş Tedavi ve İmplant Fiyat Listesi",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Medigma İmplant"
            },
            "price": "7000",
            "priceCurrency": "TRY"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Alman Bego İmplant"
            },
            "price": "9500",
            "priceCurrency": "TRY"
          },
          {
            "@type": "Offer",
