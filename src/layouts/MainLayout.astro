---
import Header from "../components/Header.astro";
import "../styles/global.css";

const { title, description } = Astro.props;

// Dil algılama mantığı (HTML lang etiketi için SEO uyumluluğu)
const pathname = Astro.url.pathname;
const pathLang = pathname.split('/')[1]; 
const currentLang = ['tr', 'en', 'de', 'bg'].includes(pathLang) ? pathLang : 'tr'; 

// Sitenin genel açıklaması (Eğer sayfadan özel description gelmezse bunu kullanır)
const metaDescription = description || "Dental Implant Clinic A Plus - Silivri ve Çatalca'da uzman hekim kadromuzla implant, zirkonyum, gülüş tasarımı ve tüm diş tedavilerinde hizmetinizdeyiz.";
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <title>{title} | Dental Implant Clinic A Plus</title>
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://api.fontshare.com" crossorigin>
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin>

    <link rel="preload" as="image" href="/images/ana-banner.webp" type="image/webp" fetchpriority="high" />
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@700,500,400&display=swap" rel="stylesheet" />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Dentist",
      "name": "Özel Silivri Dental Implant Clinic A Plus",
      "description": "Silivri ve Çatalca'da uzman hekim kadrosuyla hizmet veren, uluslararası sağlık turizmi yetki belgesine sahip tam donanımlı A Plus diş kliniği. Uzman çene cerrahları ve protez uzmanları ile hizmetinizdeyiz.",
