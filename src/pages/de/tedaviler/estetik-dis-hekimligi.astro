---
// DE (Almanca) versiyonu için:
// src/pages/de/tedaviler/estetik-dis-hekimligi.astro

import MainLayout from '../../../layouts/MainLayout.astro';
import TedaviDoktorlari from '../../../components/TedaviDoktorlari.astro'; // DOKTOR COMPONENT'İ

// SEO için sayfa başlığı ve açıklaması
const pageTitle = "Ästhetische Zahnheilkunde und Lächeln-Design | Yüceler A+ Klinik";
const pageDescription = "Ästhetische Zahnheilkunde in Silivri und Çatalca mit unserem Fachpersonal. Makelloses Lächeln mit Lamina, Zirkonium, rosa Ästhetik und digitalem Design.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/estetik-banner.webp');"></div>
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <span class="inline-block bg-klinik-koyu text-white px-4 py-1 rounded-full text-sm font-bold mb-6 tracking-widest uppercase">Individuelles Design</span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-klinik-koyu mb-6 drop-shadow-sm">
        Ästhetische <span class="text-klinik-yesil">Zahnheilkunde</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-800 font-medium max-w-xl leading-relaxed drop-shadow-sm bg-white/50 backdrop-blur-sm p-4 rounded-xl">
        Wir verwandeln Ihr Traumlachen in die Realität mit digitalem Lächeln-Design, das am besten zu Ihren Gesichtszügen passt, Porzellan-Laminat-Veneers (Lamina) und Zahnfleischästhetik.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/3 prose prose-lg prose-slate max-w-none">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Was ist Ästhetische Zahnheilkunde?</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Die ästhetische Zahnheilkunde ist der Zweig der Zahnmedizin, der nicht nur dafür sorgt, dass die Zähne gesund sind, sondern auch, dass sie in perfekter Harmonie mit den Gesichtszügen, der Lippenstruktur und dem Zahnfleisch der Person stehen. Durch den Einsatz <strong>digitaler Technologien</strong> können dem Patienten die Ergebnisse nun schon vor Beginn der Behandlung gezeigt werden.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Unser Ziel ist es, ein ästhetisches, funktionelles und individuelles "Hollywood-Lächeln" nach den Regeln des Goldenen Schnitts zu entwerfen, wobei Ihre natürliche Zahnsubstanz maximal erhalten bleibt.
          </p>

          <div class="bg-gray-50 rounded-2xl p-8 border-l-4 border-klinik-yesil mb-10">
            <h3 class="text-xl font-bold text-klinik-koyu mb-4">Welche Behandlungen umfasst die Ästhetische Zahnheilkunde?</h3>
            <ul class="space-y-3 text-gray-700 font-medium">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Porzellan-Laminat-Veneers (Lamina):</strong> Dünne ästhetische Blättchen, die nur auf die Vorderseite des Zahns aufgetragen werden.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Zirkoniumkronen:</strong> Solide Restaurationen mit hoher Lichtdurchlässigkeit und natürlichem Zahnaussehen.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Rosa Ästhetik (Gingivoplastik):</strong> Symmetrische und ästhetische Anpassung des Zahnfleischrandes.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Ästhetische Kompositfüllungen:</strong> Zahnfarbene Füllungen (Bonding), die von außen nicht sichtbar sind.</li>
            </ul>
          </div>

          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Der Prozess des digitalen Lächeln-Designs</h2>
          <div class="space-y-6 mb-10">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Digitaler Abdruck und Fotografie</h4>
                <p class="text-gray-600">Ihre Zähne werden mit Intraoralscannern in 3D gemessen. Um die Proportionen von Gesicht, Lippen und Zähnen zu analysieren, werden detaillierte Fotos in einer Studioumgebung aufgenommen.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Mock-Up (Anprobe) Anwendung</h4>
                <p class="text-gray-600">Ihre neuen, computergestützt entworfenen Zähne werden mit einem speziellen Material in Ihrem Mund angebracht, ohne dass an Ihren Zähnen ein Eingriff vorgenommen wird. So können Sie das Ergebnis sehen, bevor die Behandlung beginnt.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Behandlung und Abschluss</h4>
                <p class="text-gray-600">In Übereinstimmung mit dem von Ihnen freigegebenen Design werden Ihre Lamina-, Zirkonium- oder Bonding-Verfahren abgeschlossen und Sie erhalten Ihr neues Lächeln.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 sticky top-32">
          <img src="/images/estetik-kutu.webp" alt="Ästhetische Zahnheilkunde Vorher-Nachher" class="w-full h-64 object-cover rounded-t-2xl shadow-sm" />
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-b-2xl shadow-xl">
            <h3 class="text-2xl font-bold text-klinik-koyu mb-4">Entdecken Sie Ihr Lächeln neu</h3>
            <p class="text-gray-500 mb-6 text-sm">Lassen Sie uns gemeinsam mit einer kostenlosen Beratung den für Sie am besten geeigneten ästhetischen Behandlungsplan erstellen.</p>
            
            <a href="https://wa.me/902124000013" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#25D366] text-white font-bold py-4 px-6 rounded-xl hover:bg-green-600 transition-colors mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829z" /></svg>
              Infos über WhatsApp anfragen
            </a>
            <a href="tel:+902124000013" class="w-full flex items-center justify-center gap-2 bg-klinik-koyu text-white font-bold py-4 px-6 rounded-xl hover:bg-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Klinik anrufen: +90 212 400 00 13
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <TedaviDoktorlari tedavi="gulus-tasarimi" />

  <section class="py-20 bg-gray-50 border-t border-gray-100 pb-32">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-klinik-koyu mb-4">Häufig gestellte <span class="text-klinik-yesil">Fragen</span></h2>
        <p class="text-gray-600">Was man sich über ästhetische Zahnbehandlungen fragt.</p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Wie lange dauern ästhetische Zahnbehandlungen?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Obwohl die Dauer je nach geplanter Behandlung variiert, hat sie sich dank digitaler Abdrucksysteme erheblich beschleunigt. Lamina- oder Zirkoniumverblendungen werden in der Regel in 2 oder 3 Sitzungen, also in durchschnittlich 1 Woche, abgeschlossen.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Sind ästhetische Zahnbehandlungen schmerzhaft?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Nein, da die Eingriffe unter örtlicher Betäubung durchgeführt werden, sind während der Behandlung absolut keine Schmerzen zu spüren. Eine eventuelle leichte Empfindlichkeit nach dem Eingriff lässt sich mit einfachen Schmerzmitteln, die von unserem Arzt empfohlen werden, leicht kontrollieren.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Für wen sind Porzellan-Laminat-Veneers (Lamina) geeignet?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Sie können bei allen erwachsenen Patienten angewendet werden, die Verfärbungen an ihren Zähnen, leichte Engstände oder Lücken zwischen den Zähnen (Diastema) oder abgebrochene oder abgenutzte Zähne aufweisen. Bei Patienten mit extremem Zähneknirschen müssen möglicherweise Vorsichtsmaßnahmen getroffen werden.</p>
        </details>
      </div>
    </div>
  </section>

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Rechtliche Hinweise</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Diese Website wurde ausschließlich zur Information von Patienten in voller Übereinstimmung mit den Vorschriften des türkischen Gesundheitsministeriums erstellt.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Gemeinsames Callcenter: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Letzte Aktualisierung: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Redakteur: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>

</MainLayout>