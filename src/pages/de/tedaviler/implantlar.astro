---
// DE (Almanca) versiyonu için:
// src/pages/de/tedaviler/implantlar.astro

import MainLayout from '../../../layouts/MainLayout.astro';
import TedaviDoktorlari from '../../../components/TedaviDoktorlari.astro'; // DOKTOR BİLEŞENİ EKLENDİ

// SEO için sayfa başlığı ve açıklaması
const pageTitle = "Implantatbehandlung | Originale und garantierte Marken | Dental Implant Clinic A Plus";
const pageDescription = "100 % originale, zertifizierte Straumann-, Bego-, Nobel-, Medentika- und Medigma-Implantatbehandlungen in Silivri und Çatalca. Lebenslange dauerhafte Lösungen zu den besten Preisen.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/implant-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/95 via-klinik-koyu/60 to-transparent z-0"></div> 
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <div class="max-w-3xl">
        <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">100 % Original & Zertifiziert</span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-2xl">
          Dauerhafte Lösung für fehlende Zähne: <br/><span class="text-klinik-yesil">Implantatbehandlung</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed drop-shadow-lg">
          Implantatlösungen mit Titanwurzeln, die so stark wie Ihre natürlichen Zähne sind, mit lebenslanger Garantie und nach A Plus Standards.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/3 prose prose-lg prose-slate max-w-none">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Was ist ein Implantat?</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Implantate sind künstliche Zahnwurzeln aus gewebefreundlichem Titan, die in den Kieferknochen eingesetzt werden, um die Funktion und Ästhetik fehlender Zähne wiederherzustellen. Es ist heute die <strong>beste, natürlichste und langlebigste</strong> Methode zur Behandlung von Zahnverlust.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            In unserer Klinik werden chirurgische Eingriffe mit millimetergenauer Präzision durch 3D-Tomographie-unterstützte (Volumentomographie) digitale Planung durchgeführt. Dadurch wird die Fehlerquote auf null reduziert und die Heilungszeit maximal verkürzt.
          </p>

          <div class="bg-gray-50 rounded-2xl p-8 border-l-4 border-klinik-yesil mb-10">
            <h3 class="text-xl font-bold text-klinik-koyu mb-4">Warum sollten Sie sich für Implantate entscheiden?</h3>
            <ul class="space-y-3 text-gray-700 font-medium">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Schützt benachbarte Zähne:</strong> Gesunde Nachbarzähne müssen nicht wie bei einer Brückenbehandlung beschliffen werden.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Stoppt Knochenschwund:</strong> Verhindert den Abbau des Kieferknochens im Bereich des extrahierten Zahns.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Natürliches Kaugefühl:</strong> Sie können kräftig zubeißen und alles bequem essen, genau wie mit Ihren eigenen Zähnen.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Lebenslange Nutzung:</strong> Originale und zertifizierte Implantate bleiben bei guter Pflege ein Leben lang erhalten.</li>
            </ul>
          </div>

          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Wie wird die Implantatbehandlung durchgeführt?</h2>
          <div class="space-y-6">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">3D-Tomographie und digitale Planung</h4>
                <p class="text-gray-600">Die Dicke Ihres Kieferknochens, die Lage der Nerven und die Knochendichte werden mittels 3D-Tomographie detailliert untersucht. Die Position des Implantats wird millimetergenau digital geplant.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Chirurgischer Eingriff (Einsetzen des Implantats)</h4>
                <p class="text-gray-600">Unter örtlicher Betäubung (völlig schmerzfrei) wird die künstliche Titanwurzel in den Kieferknochen eingesetzt. Oft dauert das Einsetzen eines einzelnen Implantats nur 15-20 Minuten.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Einheilung und Suprakonstruktion (Porzellan)</h4>
                <p class="text-gray-600">Es wird 2 bis 3 Monate gewartet, bis das Implantat mit dem Kieferknochen verschmolzen ist. Der Prozess wird abgeschlossen, indem Ihr ästhetischer Porzellan- oder Zirkoniumzahn auf dem mit dem Knochen integrierten Implantat befestigt wird.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 sticky top-32">
          <img src="/images/implant-kutu.webp" alt="3D Implantatbehandlung" class="w-full h-64 object-cover rounded-t-2xl shadow-sm" />
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-b-2xl shadow-xl">
            <h3 class="text-2xl font-bold text-klinik-koyu mb-4">Kostenlose Tomographie & Untersuchung</h3>
            <p class="text-gray-500 mb-6 text-sm">Finden Sie mit unserem 3D-Tomographiegerät kostenlos heraus, ob Ihre Knochenstruktur für Implantate geeignet ist.</p>
            
            <a href="https://wa.me/902124000013" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#25D366] text-white font-bold py-4 px-6 rounded-xl hover:bg-green-600 transition-colors mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829z" /></svg>
              Infos über WhatsApp anfragen
            </a>
            <a href="tel:+902124000013" class="w-full flex items-center justify-center gap-2 bg-klinik-koyu text-white font-bold py-4 px-6 rounded-xl hover:bg-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Klinik anrufen: +90 212 400 00 13
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-24 bg-[#F8FAFC]">
    <div class="container mx-auto px-4 max-w-7xl">
        <div class="bg-white rounded-[40px] p-8 md:p-16 shadow-xl border border-gray-100 flex flex-col lg:flex-row gap-16 items-start relative overflow-hidden">
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-klinik-yesil/5 rounded-full blur-3xl pointer-events-none"></div>

            <div class="w-full lg:w-1/2 relative z-10">
                <span class="inline-block bg-klinik-turuncu text-white px-4 py-1 rounded-full text-xs font-bold mb-4 tracking-widest uppercase">Transparente Preispolitik</span>
                <h2 class="text-3xl md:text-4xl font-bold text-[#1E293B] leading-tight mb-6">
                    Wir bieten Ihnen 100 % original zertifizierte,<br />
                    <span class="text-[#334155]">garantierte</span> Implantate an
                </h2>
                <p class="text-gray-500 mb-8 text-sm md:text-base leading-relaxed">
                    Als Dental Implant Clinic A Plus Poliklinik für Mund- und Zahngesundheit bieten wir Ihnen die günstigsten Premium-Implantatlösungen der Türkei mit Barcode und internationalem Garantiepass.
                </p>
                
                <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-100">
                  <ul class="space-y-4 text-[#1E293B] font-bold text-sm md:text-base">
                      <li class="flex items-center justify-between border-b border-gray-200 pb-2">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Straumann Implantat</span> 
                        <span class="text-klinik-turuncu">€ 400</span>
                      </li>
                      <li class="flex items-center justify-between border-b border-gray-200 pb-2">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Nobel Biocare Implantat</span> 
                        <span class="text-klinik-turuncu">€ 300</span>
                      </li>
                      <li class="flex items-center justify-between border-b border-gray-200 pb-2">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Medentika Implantat</span> 
                        <span class="text-klinik-turuncu">€ 140</span>
                      </li>
                      <li class="flex items-center justify-between border-b border-gray-200 pb-2">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Bego Implantat</span> 
                        <span class="text-klinik-turuncu">€ 95</span>
                      </li>
                      <li class="flex items-center justify-between">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Medigma Implantat</span> 
                        <span class="text-klinik-turuncu">€ 70</span>
                      </li>
                  </ul>
                </div>
                
                <a href="https://wa.me/902124000013" target="_blank" class="inline-flex items-center gap-4 bg-[#212E3D] text-white pl-2 pr-8 py-2 rounded-xl font-bold hover:bg-black transition-all shadow-xl group">
                    <div class="bg-[#5C8AB4] p-3 rounded-lg group-hover:bg-klinik-yesil transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                    </div>
                    Originalprodukt-Anfrage
                </a>
            </div>

            <div class="w-full lg:w-1/2 flex flex-col pt-8 lg:pt-0 relative z-10">
                {[
                    { name: 'Straumann Implantat', logo: 'straumann.svg' },
                    { name: 'Nobel Biocare Implantat', logo: 'nobel.svg' },
                    { name: 'Medentika Implantat', logo: 'medentika.svg' },
                    { name: 'Bego Implantat', logo: 'bego.svg' },
                    { name: 'Medigma Implantat', logo: 'medigma.svg' }
                ].map((brand) => (
                    <div class="flex items-center justify-start gap-8 py-6 border-b border-gray-100 last:border-0 hover:bg-gray-50 px-6 rounded-xl transition-colors group">
                        <img src={`/icons/${brand.logo}`} alt={brand.name} class="h-10 md:h-12 w-28 md:w-36 object-contain grayscale group-hover:grayscale-0 transition-all duration-300" />
                        <span class="text-lg md:text-xl font-bold text-[#475569] group-hover:text-klinik-yesil transition-colors">{brand.name}</span>
                    </div>
                ))}
            </div>
        </div>
    </div>
  </section>

  <TedaviDoktorlari tedavi="implantlar" />

  <section class="py-20 bg-white pb-32">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-klinik-koyu mb-4">Häufig gestellte <span class="text-klinik-yesil">Fragen</span></h2>
        <p class="text-gray-600">Was unsere Patienten am meisten über die Implantatbehandlung wissen wollen.</p>
      </div>

      <div class="space-y-4">
        <details class="group bg-gray-50 rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Habe ich während oder nach der Implantatoperation Schmerzen?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Da das Implantatverfahren unter örtlicher Betäubung durchgeführt wird, sind während des chirurgischen Eingriffs absolut keine Schmerzen zu spüren. Leichte Beschwerden, die nach dem Nachlassen der Betäubung auftreten können, lassen sich mit den von unserem Arzt verschriebenen Standard-Schmerzmitteln leicht kontrollieren.</p>
        </details>

        <details class="group bg-gray-50 rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Besteht die Gefahr, dass der Körper das Implantat abstößt?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Implantate werden aus gewebefreundlichem (biokompatiblem) Reintitan hergestellt. Biologisch gesehen ist es dem menschlichen Körper nicht möglich, Antikörper gegen Titan zu bilden und es wie bei Herz- oder Nierentransplantationen abzustoßen. Bei Verwendung von Original- und zertifizierten Produkten liegt die Erfolgsquote bei über 98 %.</p>
        </details>

        <details class="group bg-gray-50 rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Können Zahnextraktion und Implantat am selben Tag durchgeführt werden?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Ja, mit dieser Technik, die wir "Sofortimplantat" (Immediate Implant) nennen, kann Ihr Implantat in einer einzigen Sitzung sofort in dasselbe Fach eingesetzt werden, in dem Ihr Zahn gezogen wurde, sofern keine akute Infektion in Ihrem Kieferknochen vorliegt und Ihre Knochenstruktur geeignet ist.</p>
        </details>
      </div>
    </div>
  </section>

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Rechtliche Hinweise</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Diese Website wurde ausschließlich zur Information von Patienten in voller Übereinstimmung mit den Vorschriften des türkischen Gesundheitsministeriums erstellt.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Gemeinsames Callcenter: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Letzte Aktualisierung: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Redakteur: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>

</MainLayout>