---
// DE (Almanca) versiyonu için:
// src/pages/de/tedaviler/all-on-six.astro

import MainLayout from '../../../layouts/MainLayout.astro';
import TedaviDoktorlari from '../../../components/TedaviDoktorlari.astro'; 

const pathname = Astro.url.pathname;
const pathLang = pathname.split('/')[1]; 
const currentLang = ['tr', 'en', 'de', 'bg'].includes(pathLang) ? pathLang : 'tr'; 

const ui = {
  tr: { title1: "Bu Tedaviyi Uygulayan", title2: "Hekimlerimiz", all: "Tümü", noData: "Bu tedavi için atanmış doktor bulunamadı." },
  en: { title1: "Doctors Performing", title2: "This Treatment", all: "All", noData: "No doctors found for this treatment." },
  de: { title1: "Ärzte für diese", title2: "Behandlung", all: "Alle", noData: "Keine Ärzte für diese Behandlung gefunden." },
  bg: { title1: "Лекари, извършващи", title2: "това лечение", all: "Всички", noData: "Няма намерени лекари за това лечение." }
};
const t = ui[currentLang];

const pageTitle = "All On 6 Implantatbehandlung | Feste und starke Zähne | Yüceler A+ Klinik";
const pageDescription = "All-on-6 Implantatbehandlung bei völliger Zahnlosigkeit in Silivri und Çatalca. Erhalten Sie maximale Stabilität und lebenslang garantierte feste Zähne mit 6 Implantaten.";

import doktorlarData from '../../../data/doktorlar.json';
const ilgiliDoktorlar = doktorlarData.filter(doktor => 
  doktor.uzmanlik_alanlari.includes("all-on-six") || 
  doktor.uzmanlik_alanlari.includes("implant") ||
  doktor.uzmanlik_alanlari.includes("cene-cerrahisi")
);
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/all-on-six-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/95 via-klinik-koyu/60 to-transparent z-0"></div> 
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <div class="max-w-3xl">
        <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">Maximale Stabilität</span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-2xl">
          Starke und feste Lösung: <br/><span class="text-klinik-yesil">All On 6 Implantate</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed drop-shadow-lg">
          Für unsere Patienten, die alle Zähne verloren haben, bieten wir eine feste Prothesenbehandlung an, die mit 6 in den Kieferknochen eingesetzten Titanimplantaten so stark ist wie Ihre natürlichen Zähne.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/3 prose prose-lg prose-slate max-w-none">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Was ist die All-On-6 Implantattechnik?</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Das <strong>All On 6 Implantatsystem</strong> ist eine fortschrittliche chirurgische Technik, die bei Patienten mit völliger Zahnlosigkeit angewendet wird. Dabei werden 6 Titanimplantate in bestimmten Winkeln und Abständen in einem einzigen Kiefer platziert und darauf festsitzende Porzellan- oder Zirkoniumbrücken angebracht.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Im Gegensatz zur All-On-4-Technik sorgen die 2 zusätzlichen Implantate im hinteren Bereich dafür, dass die <strong>Kaukraft viel ausgewogener und gleichmäßiger auf den Kieferknochen verteilt wird.</strong> All On 6 wird bei Patienten mit ausreichendem Knochenvolumen bevorzugt und gehört in Bezug auf langfristige mechanische Haltbarkeit zu den höchsten erreichbaren Behandlungsstandards.
          </p>

          <div class="bg-gray-50 rounded-2xl p-8 border-l-4 border-klinik-yesil mb-10">
            <h3 class="text-xl font-bold text-klinik-koyu mb-4">Was sind die Vorteile der All-On-6 Behandlung?</h3>
            <ul class="space-y-3 text-gray-700 font-medium">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Maximale Stabilität:</strong> Die Verwendung von 6 Implantaten sorgt dafür, dass sich die Prothese in keiner Weise biegt und vollständig am Knochen haftet.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Hervorragende Kaufunktion:</strong> Sie können alle Arten harter Lebensmittel bequem essen, genau wie mit Ihren eigenen natürlichen Zähnen.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Schluss mit Gaumenprothesen:</strong> Beseitigt vollständig Druckstellen, Geschmacksverlust und Sprachstörungen, die durch herausnehmbare Prothesen verursacht werden.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Stoppt Knochenschwund:</strong> Da die Implantate als natürliche Zahnwurzeln fungieren, stimulieren sie den Kieferknochen und verhindern dessen Abbau.</li>
            </ul>
          </div>

          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Wie verläuft der All-On-6 Behandlungsprozess?</h2>
          <div class="space-y-6 mb-10">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">3D-Tomographie und digitale Planung</h4>
                <p class="text-gray-600">Das Volumen und die Dichte Ihres Kieferknochens werden mit einer 3D-Tomographie analysiert. Die idealen Positionen für die 6 Implantate im Knochen werden millimetergenau in einer digitalen Umgebung bestimmt.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Chirurgischer Eingriff und provisorische Zähne</h4>
                <p class="text-gray-600">Unter örtlicher Betäubung werden 6 Implantate in den Kieferknochen eingesetzt. Bei ausreichender Knochenqualität (hohe Primärstabilität) werden noch am Tag der Operation provisorische feste Zähne auf die Implantate geschraubt.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Einsetzen der dauerhaften Zähne</h4>
                <p class="text-gray-600">Nach einer durchschnittlichen Heilungsphase (Einwachsen in den Knochen) von 3 Monaten werden Ihre provisorischen Zähne entfernt und Ihre ästhetisch an Ihre Gesichtszüge angepassten dauerhaften Porzellan-/Zirkoniumzähne eingesetzt.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 sticky top-32">
          <img src="/images/all-on-six-kutu.webp" alt="All On 6 Implantatbehandlung" class="w-full h-64 object-cover rounded-t-2xl shadow-sm" />
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-b-2xl shadow-xl">
            <h3 class="text-2xl font-bold text-klinik-koyu mb-4">Gewinnen Sie Ihr starkes Beißgefühl zurück</h3>
            <p class="text-gray-500 mb-6 text-sm">Lassen Sie uns mit einer kostenlosen 3D-Tomographie die Eignung Ihres Kieferknochens für die All-On-6-Behandlung überprüfen.</p>
            
            <a href="https://wa.me/902124000013" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#25D366] text-white font-bold py-4 px-6 rounded-xl hover:bg-green-600 transition-colors mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829z" /></svg>
              Preise über WhatsApp anfragen
            </a>
            <a href="tel:+902124000013" class="w-full flex items-center justify-center gap-2 bg-klinik-koyu text-white font-bold py-4 px-6 rounded-xl hover:bg-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Klinik anrufen: +90 212 400 00 13
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  {ilgiliDoktorlar.length > 0 && (
    <section class="py-16 bg-white border-t border-gray-100">
      <div class="container mx-auto px-4 max-w-6xl">
        
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-klinik-koyu">{t.title1} <span class="text-klinik-yesil">{t.title2}</span></h2>
          </div>
          
          <div class="flex bg-gray-50 p-1 rounded-full border border-gray-200">
            <button class="tedavi-filtre-btn px-5 py-1.5 rounded-full text-xs font-bold transition-all bg-klinik-yesil text-white shadow-sm" data-hedef="all">{t.all}</button>
            <button class="tedavi-filtre-btn px-5 py-1.5 rounded-full text-xs font-bold transition-all text-gray-500 hover:text-klinik-koyu" data-hedef="silivri">Silivri</button>
            <button class="tedavi-filtre-btn px-5 py-1.5 rounded-full text-xs font-bold transition-all text-gray-500 hover:text-klinik-koyu" data-hedef="catalca">Çatalca</button>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 tedavi-doktor-grid">
          {ilgiliDoktorlar.map((doktor) => (
            <a href={`/${currentLang}/doktorlar/${doktor.id}`} class="tedavi-doktor-card group bg-gray-50 rounded-2xl p-4 text-center border border-gray-100 hover:border-klinik-yesil hover:shadow-md transition-all flex flex-col items-center justify-center cursor-pointer" data-klinikler={doktor.klinikler.join(',')}>
              <div class="w-20 h-20 rounded-full bg-white shadow-sm overflow-hidden mb-3 border border-gray-200 group-hover:scale-105 transition-transform duration-300">
                <img 
                  src={doktor.resim} 
                  alt={doktor.isim} 
                  class="w-full h-full object-cover"
                  onerror="this.src='/images/doktor-placeholder.webp';"
                />
              </div>
              <h3 class="text-sm font-extrabold text-klinik-koyu leading-tight group-hover:text-klinik-yesil transition-colors">{doktor.isim}</h3>
              
              <p class="text-[10px] text-gray-500 font-bold mt-1 uppercase tracking-wider line-clamp-1">{doktor.unvan[currentLang]}</p>
            </a>
          ))}
        </div>

      </div>
    </section>
  )}
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('.tedavi-filtre-btn');
      const docCards = document.querySelectorAll('.tedavi-doktor-card');

      if(filterBtns.length > 0 && docCards.length > 0) {
        filterBtns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            filterBtns.forEach(b => {
              b.classList.remove('bg-klinik-yesil', 'text-white', 'shadow-sm');
              b.classList.add('text-gray-500');
            });
            
            const target = e.currentTarget;
            target.classList.remove('text-gray-500');
            target.classList.add('bg-klinik-yesil', 'text-white', 'shadow-sm');

            const branch = target.getAttribute('data-hedef');
            docCards.forEach(card => {
              const klins = card.getAttribute('data-klinikler') || "";
              if(branch === 'all' || klins.includes(branch)) {
                card.style.display = 'flex';
              } else {
                card.style.display = 'none';
              }
            });
          });
        });
      }
    });
  </script>

  <section class="py-20 bg-gray-50 border-t border-gray-100 pb-32">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-klinik-koyu mb-4">Häufig gestellte <span class="text-klinik-yesil">Fragen</span></h2>
        <p class="text-gray-600">Was unsere Patienten am meisten über die All-On-6 Implantatbehandlung wissen wollen.</p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Was ist der Unterschied zwischen All-On-4 und All-On-6?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Wie die Namen schon andeuten, ist der Hauptunterschied die Anzahl der verwendeten Implantate. Bei All-On-6 werden 2 zusätzliche Implantate in die hinteren Kieferbereiche eingesetzt. Dadurch wird die Prothese auf einer größeren Fläche abgestützt und die Kaukraft perfekter auf den Kiefer verteilt. Für All-On-6 muss jedoch eine ausreichende Knochendichte im hinteren Bereich vorhanden sein; fehlt der Knochen, wird All-On-4 bevorzugt.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Wie lange dauert der chirurgische Eingriff, werde ich Schmerzen haben?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Da der Eingriff vollständig unter örtlicher Betäubung durchgeführt wird, werden Sie während der Operation absolut keine Schmerzen spüren. Das Einsetzen von 6 Implantaten dauert im Durchschnitt 1,5 - 2 Stunden für einen einzelnen Kiefer.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Kann All-On-6 auch bei Knochenschwund durchgeführt werden?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Wenn der Knochenschwund in den hinteren Bereichen nicht sehr weit fortgeschritten ist, kann das Knochenvolumen durch Sinuslift (Anheben der Sinusmembran) und Zugabe von Knochenersatzmaterial vergrößert werden, um All-On-6 durchzuführen. Ohne eine 3D-Tomographie ist es nicht möglich, eine definitive Aussage zu treffen.</p>
        </details>
      </div>
    </div>
  </section>

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Rechtliche Hinweise</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Diese Website wurde ausschließlich zur Information von Patienten in voller Übereinstimmung mit den Vorschriften des türkischen Gesundheitsministeriums erstellt.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Gemeinsames Callcenter: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Letzte Aktualisierung: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Redakteur: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>

</MainLayout>