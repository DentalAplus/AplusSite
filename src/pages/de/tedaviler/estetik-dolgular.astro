---
// DE (Almanca) versiyonu için:
// src/pages/de/tedaviler/estetik-dolgular.astro

import MainLayout from '../../../layouts/MainLayout.astro';
import TedaviDoktorlari from '../../../components/TedaviDoktorlari.astro'; // DOKTOR BİLEŞENİ EKLENDİ

// SEO için sayfa başlığı ve açıklaması
const pageTitle = "Ästhetische Kompositfüllung und Bonding | Yüceler A+ Klinik";
const pageDescription = "Ästhetische Kompositfüllung und Bonding-Behandlung in Silivri und Çatalca. Wir ersetzen Ihre alten schwarzen Füllungen durch natürliche und langlebige Füllungen, die genau zu Ihrer Zahnfarbe passen.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/estetik-dolgu-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/95 via-klinik-koyu/60 to-transparent z-0"></div> 
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <div class="max-w-3xl">
        <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">Natürlich und Unsichtbar</span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-2xl">
          Unsichtbare <br/><span class="text-klinik-yesil">Ästhetische Füllungen</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed drop-shadow-lg">
          Wir erneuern Ihr Lächeln in einer einzigen Sitzung mit langlebigen und ästhetischen Kompositfüllungen (Bonding), die vollständig auf Ihre Zahnfarbe abgestimmt und quecksilberfrei sind.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/3 prose prose-lg prose-slate max-w-none">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Was ist eine ästhetische Kompositfüllung (Bonding)?</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Als Ersatz für alte, schwarze und quecksilberhaltige Amalgamfüllungen sind <strong>ästhetische Kompositfüllungen</strong> Restaurationsmaterialien der neuen Generation, die sich exakt an die natürliche Farbe, Lichtdurchlässigkeit und Textur des Zahns anpassen.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Diese Methode, die insbesondere zum Schließen von Lücken zwischen den Frontzähnen (Diastema), zum Reparieren von Brüchen, zur Beseitigung von Verfärbungen oder zur Verlängerung von Zähnen eingesetzt wird, wird <strong>Bonding</strong> genannt. Es ist eine präventive ästhetische Behandlung, die Wunder in einer einzigen Sitzung bewirkt, ohne das Zahngewebe zu beschädigen.
          </p>

          <div class="bg-gray-50 rounded-2xl p-8 border-l-4 border-klinik-yesil mb-10">
            <h3 class="text-xl font-bold text-klinik-koyu mb-4">Was sind die Vorteile von ästhetischen Füllungen?</h3>
            <ul class="space-y-3 text-gray-700 font-medium">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Natürliches Aussehen:</strong> Sie werden speziell für Ihre Zahnfarbe ausgewählt, von außen ist nicht erkennbar, dass es sich um eine Füllung handelt.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Schont das Gewebe:</strong> Nur die Karies wird gereinigt, es ist nicht nötig, zusätzliche Hohlräume wie bei alten Füllungen zu schaffen.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Schnelle Lösung:</strong> Wird in einer einzigen Sitzung durch Aushärten mit speziellen Strahlen abgeschlossen und kann sofort verwendet werden.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Sicher und Gesund:</strong> Enthält kein Quecksilber oder schädliche Schwermetalle und ist völlig gewebefreundlich.</li>
            </ul>
          </div>

          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Ablauf der Anwendung (Schritt für Schritt)</h2>
          <div class="space-y-6 mb-10">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Reinigung und Vorbereitung</h4>
                <p class="text-gray-600">Unter örtlicher Betäubung wird Karies oder eine alte problematische Füllung gereinigt. Die Zahnoberfläche wird mit speziellen Gelen auf Mikroebene aufgeraut, damit das Kompositmaterial haften kann.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Schichtverfahren (Layering)</h4>
                <p class="text-gray-600">Durch die Nachahmung des natürlichen Zahnschmelzes und der Dentinfarben wird das ausgewählte Kompositmaterial Schicht für Schicht auf den Zahn aufgetragen und anatomisch geformt.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Bestrahlung und perfekte Politur</h4>
                <p class="text-gray-600">Das Material wird mit speziellen LED-Strahlen ausgehärtet. Im letzten Schritt wird eine perfekte Politur angewendet, um Unebenheiten zu beseitigen und den natürlichen Glanz des Zahns zu erzielen.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 sticky top-32">
          <img src="/images/estetik-dolgu-kutu.webp" alt="Ästhetische Kompositfüllung Vorher Nachher" class="w-full h-64 object-cover rounded-t-2xl shadow-sm" />
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-b-2xl shadow-xl">
            <h3 class="text-2xl font-bold text-klinik-koyu mb-4">Verabschieden Sie sich von schwarzen Füllungen</h3>
            <p class="text-gray-500 mb-6 text-sm">Kontaktieren Sie uns, um Ihre alten schwarzen Füllungen durch ästhetische weiße Füllungen zu ersetzen oder Ihre abgebrochenen Frontzähne zu reparieren.</p>
            
            <a href="https://wa.me/902124000013" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#25D366] text-white font-bold py-4 px-6 rounded-xl hover:bg-green-600 transition-colors mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829z" /></svg>
              Preise über WhatsApp anfragen
            </a>
            <a href="tel:+902124000013" class="w-full flex items-center justify-center gap-2 bg-klinik-koyu text-white font-bold py-4 px-6 rounded-xl hover:bg-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Klinik anrufen: +90 212 400 00 13
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <TedaviDoktorlari tedavi="estetik-dolgular" />

  <section class="py-20 bg-gray-50 border-t border-gray-100 pb-32">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-klinik-koyu mb-4">Häufig gestellte <span class="text-klinik-yesil">Fragen</span></h2>
        <p class="text-gray-600">Was man sich über ästhetische Füllungen und Bonding-Verfahren fragt.</p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Wie lange halten ästhetische (Komposit-)Füllungen?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Dank fortschrittlicher Technologie sind Kompositfüllungen der neuen Generation gegenüber Kaukräften mindestens so widerstandsfähig wie alte Amalgamfüllungen. Bei richtiger Politur und regelmäßiger Mundpflege können sie viele Jahre sicher verwendet werden.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Sollte ich meine schwarzen (Amalgam-)Füllungen ersetzen lassen?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Amalgamfüllungen können mit der Zeit ihre Randanpassung verlieren, und darunter kann sich versteckte Karies bilden. Zudem ist es heutzutage ein Standard und ein gesunder Ansatz, sie aufgrund der enthaltenen Schwermetalle und des unästhetischen schwarzen Aussehens durch gesunde Kompositfüllungen zu ersetzen.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Wie lange dauert eine Bonding-Behandlung (Frontzahnästhetik)?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Das Bonding-Verfahren wird in der Regel in einer einzigen Sitzung (30-60 Minuten) abgeschlossen, abhängig von der Größe des Schadens oder der Lücke im Zahn. Es gibt Fälle, in denen nicht einmal eine Betäubung erforderlich ist, und der Patient verlässt die Klinik sofort mit einem ästhetischen Ergebnis.</p>
        </details>
      </div>
    </div>
  </section>

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Rechtliche Hinweise</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Diese Website wurde ausschließlich zur Information von Patienten in voller Übereinstimmung mit den Vorschriften des türkischen Gesundheitsministeriums erstellt.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Gemeinsames Callcenter: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Letzte Aktualisierung: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Redakteur: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>

</MainLayout>