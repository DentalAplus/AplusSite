<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script is:inline>
  const slider = document.getElementById('doctorsSlider');
  const cards = document.querySelectorAll('.doctor-card');
  const btnAll = document.getElementById('filterAll');
  const btnSilivri = document.getElementById('filterSilivri');
  const btnCatalca = document.getElementById('filterCatalca');
  const leftBtn = document.getElementById('slideLeftBtn');
  const rightBtn = document.getElementById('slideRightBtn');
  let autoScrollTimer;

  // 1. FİLTRELEME MOTORU
  function updateFilters(branch, activeBtn) {
    if(!btnAll) return;
    [btnAll, btnSilivri, btnCatalca].forEach(btn => {
      btn.classList.remove('bg-klinik-yesil', 'text-white', 'shadow-md');
      btn.classList.add('text-gray-600');
    });
    activeBtn.classList.add('bg-klinik-yesil', 'text-white', 'shadow-md');

    cards.forEach(card => {
      const klinikler = card.getAttribute('data-klinikler').split(',');
      if (branch === 'all' || klinikler.includes(branch)) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
    if(slider) slider.scrollLeft = 0;
  }

  btnAll?.addEventListener('click', () => updateFilters('all', btnAll));
  btnSilivri?.addEventListener('click', () => updateFilters('silivri', btnSilivri));
  btnCatalca?.addEventListener('click', () => updateFilters('catalca', btnCatalca));

  // 2. ELİT VE ZARİF KAYMA MOTORU
  function startEliteScroll() {
    if(!slider) return;
    stopScroll();
    autoScrollTimer = setInterval(() => {
      const cardWidth = 340; 
      if (slider.scrollLeft + slider.clientWidth >= slider.scrollWidth - 10) {
        slider.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        slider.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }
    }, 4000);
  }

  function stopScroll() { clearInterval(autoScrollTimer); }

  if (slider) {
    startEliteScroll();
    slider.addEventListener('mouseenter', stopScroll);
    slider.addEventListener('mouseleave', startEliteScroll);
    slider.addEventListener('touchstart', stopScroll, {passive: true});
    slider.addEventListener('touchend', startEliteScroll);

    leftBtn?.addEventListener('click', () => { slider.scrollBy({ left: -340, behavior: 'smooth' }); stopScroll(); });
    rightBtn?.addEventListener('click', () => { slider.scrollBy({ left: 340, behavior: 'smooth' }); stopScroll(); });
  }
</script>