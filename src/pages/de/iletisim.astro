---
import MainLayout from '../../layouts/MainLayout.astro';

// SEO ayarları
const pageTitle = "İletişim & Randevu | Dental Implant Clinic A Plus";
const pageDescription = "Silivri ve Çatalca şubelerimizden randevu almak, diş tedavisi fiyatlarını öğrenmek veya online danışmanlık almak için hemen bizimle iletişime geçin.";
