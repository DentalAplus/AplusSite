---
import MainLayout from '../../../layouts/MainLayout.astro';
import doktorlarData from '../../../data/doktorlar.json';

// Astro'nun en önemli fonksiyonu: Hangi sayfaların üretileceğini sisteme söylüyoruz.
export async function getStaticPaths() {
  return doktorlarData.map((doktor) => {
    return {
      params: { id: doktor.id }, // URL'deki isim (örn: ugur-alpar)
      props: { doktor },         // O isme ait doktorun tüm verileri
    };
  });
}

// Seçilen doktorun verilerini alıyoruz
const { doktor } = Astro.props;

// DİLİ OTOMATİK ALGILAMA MANTIĞI EKLENDİ
const pathname = Astro.url.pathname;
const pathLang = pathname.split('/')[1]; 
const currentLang = ['tr', 'en', 'de', 'bg'].includes(pathLang) ? pathLang : 'tr'; 

// SABİT ÇEVİRİLER
const ui = {
  tr: { home: "Ana Sayfa", docs: "Uzmanlarımız", branches: "Hizmet Verdiği Şubeler", silivri: "Silivri Merkez Kliniği", catalca: "Çatalca Kliniği", about: "Özgeçmiş", expert: "Tıbbi İlgi Alanları", orgs: "Üye Olduğu Dernekler", book: "Hemen Randevu Al" },
  en: { home: "Home", docs: "Our Experts", branches: "Branches Served", silivri: "Silivri Central Clinic", catalca: "Catalca Clinic", about: "Biography", expert: "Medical Interests", orgs: "Memberships", book: "Book an Appointment" },
  de: { home: "Startseite", docs: "Unsere Experten", branches: "Bediente Filialen", silivri: "Silivri Zentralklinik", catalca: "Catalca Klinik", about: "Biografie", expert: "Medizinische Interessen", orgs: "Mitgliedschaften", book: "Termin Buchen" },
  bg: { home: "Начало", docs: "Нашите експерти", branches: "Клонове на обслужване", silivri: "Централна клиника Силиври", catalca: "Клиника Чаталджа", about: "Биография", expert: "Медицински интереси", orgs: "Членства", book: "Резервирайте час" }
};
const t = ui[currentLang];

// SEO ayarları (HATA BURADAYDI, DÜZELTİLDİ: doktor.ozgecmis[currentLang].substring)
const pageTitle = `${doktor.isim} - ${doktor.unvan[currentLang]} | Dental Implant Clinic A Plus`;
const pageDescription = `${doktor.isim} profil sayfası. ${doktor.ozgecmis[currentLang].substring(0, 150)}...`;
---

<MainLayout title={pageTitle}>
  <section class="relative pt-32 pb-20 bg-klinik-koyu overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-10" style="background-image: url('/images/fiyat-listesi-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-klinik-koyu to-transparent"></div>
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10">
      <nav class="flex text-sm text-gray-400 mb-6 font-medium">
        <a href={`/${currentLang}`} class="hover:text-klinik-turuncu transition-colors">{t.home}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-500">{t.docs}</span>
        <span class="mx-2">/</span>
        <span class="text-white">{doktor.isim}</span>
      </nav>
      <div class="flex items-center gap-3">
        <div class="w-10 h-1 bg-klinik-turuncu rounded-full"></div>
        <span class="text-klinik-turuncu font-bold tracking-widest uppercase">{doktor.unvan[currentLang]}</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mt-3">{doktor.isim}</h1>
      {doktor.alt_unvan && <p class="text-xl text-gray-300 mt-2 font-light">{doktor.alt_unvan[currentLang]}</p>}
    </div>
  </section>

  <section class="py-16 bg-[#F8FAFC]">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col md:flex-row gap-12 lg:gap-20">
        
        <div class="w-full md:w-1/3 flex flex-col gap-6">
          <div class="bg-white rounded-[2rem] p-4 shadow-xl border border-gray-100 relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <img 
               src={doktor.resim} 
               alt={doktor.isim} 
               class="w-full h-auto object-cover rounded-2xl bg-gray-50"
              onerror="this.src='/images/doktor-placeholder.webp'; this.onerror=null;"
            />
          </div>
          <a href={`/${currentLang}/iletisim`} class="w-full bg-klinik-koyu text-white font-extrabold py-5 rounded-2xl hover:bg-klinik-yesil hover:shadow-lg transition-all duration-300 flex justify-center items-center gap-2 text-lg">
            {t.book}
            <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
          </a>
          
          <div class="bg-white rounded-2xl p-6 shadow-md border border-gray-100">
            <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4">{t.branches}</h3>
            <div class="flex flex-col gap-3">
              {doktor.klinikler.includes('silivri') && (
                <div class="flex items-center gap-3 text-klinik-koyu font-bold">
                  <div class="w-2 h-2 rounded-full bg-klinik-yesil"></div> {t.silivri}
                </div>
              )}
              {doktor.klinikler.includes('catalca') && (
                <div class="flex items-center gap-3 text-klinik-koyu font-bold">
                  <div class="w-2 h-2 rounded-full bg-klinik-turuncu"></div> {t.catalca}
                </div>
              )}
            </div>
          </div>
        </div>

        <div class="w-full md:w-2/3">
          
          <div class="bg-white rounded-[2rem] p-8 md:p-12 shadow-xl border border-gray-100 mb-8">
            <h2 class="text-2xl font-bold text-klinik-koyu mb-6 flex items-center gap-3 border-b border-gray-100 pb-4">
              <svg class="w-6 h-6 text-klinik-turuncu" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
              {t.about}
            </h2>
            <div class="prose prose-lg text-gray-600 leading-relaxed max-w-none">
              <p>{doktor.ozgecmis[currentLang]}</p>
            </div>
          </div>

          {doktor.uzmanlik_alanlari && doktor.uzmanlik_alanlari.length > 0 && (
            <div class="bg-white rounded-[2rem] p-8 md:p-12 shadow-xl border border-gray-100 mb-8">
              <h2 class="text-2xl font-bold text-klinik-koyu mb-6 flex items-center gap-3 border-b border-gray-100 pb-4">
                <svg class="w-6 h-6 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                {t.expert}
              </h2>
              <div class="flex flex-wrap gap-3">
                {doktor.uzmanlik_alanlari.map((alan) => (
                  <span class="px-4 py-2 bg-gray-50 border border-gray-200 text-gray-700 rounded-xl font-medium shadow-sm hover:border-klinik-yesil hover:text-klinik-yesil transition-colors cursor-default">
                    {alan.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
                  </span>
                ))}
              </div>
            </div>
          )}

          {doktor.dernekler && doktor.dernekler[currentLang] && doktor.dernekler[currentLang].length > 0 && (
            <div class="bg-white rounded-[2rem] p-8 md:p-12 shadow-xl border border-gray-100">
              <h2 class="text-2xl font-bold text-klinik-koyu mb-6 flex items-center gap-3 border-b border-gray-100 pb-4">
                <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                {t.orgs}
              </h2>
              <ul class="space-y-3">
                {doktor.dernekler[currentLang].map((dernek) => (
                  <li class="flex items-center gap-3 text-gray-600 font-medium">
                    <div class="w-1.5 h-1.5 rounded-full bg-blue-500 shrink-0"></div>
                    {dernek}
                  </li>
                ))}
              </ul>
            </div>
          )}

        </div>
      </div>
    </div>
  </section>

  <div class="h-16 md:hidden block"></div>
  
  <div class="hidden md:flex flex-col fixed bottom-8 left-8 z-[100] gap-4">
    <a href="tel:+902124000013" class="bg-blue-600 text-white p-4 rounded-full shadow-2xl hover:scale-110 hover:bg-blue-700 transition-all duration-300 flex items-center justify-center group relative">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.864-1.051l-3.215-.536a2.25 2.25 0 0 0-2.15.586l-1.48 1.48a18.04 18.04 0 0 1-7.143-7.143l1.48-1.48a2.25 2.25 0 0 0 .586-2.15l-.536-3.215A2.25 2.25 0 0 0 7.372 2.25H6.002c-1.243 0-2.25 1.007-2.25 2.25Z" /></svg>
      <span class="absolute left-16 bg-gray-900 text-white px-3 py-1.5 rounded-md text-sm font-bold opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg">Hemen Ara</span>
    </a>
    <a href="https://wa.me/902124000013" target="_blank" class="bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 hover:bg-green-600 transition-all duration-300 flex items-center justify-center group relative">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829zM10.826 6.299c-.198-.444-.405-.453-.591-.462-.152-.007-.327-.008-.501-.008-.175 0-.457.066-.696.326-.239.261-.913.892-.913 2.176s.935 2.523 1.066 2.697c.13.174 1.84 2.808 4.456 3.907 1.838.772 2.28.618 2.671.583.391-.035 1.261-.515 1.435-1.013.174-.499.174-.925.122-1.013-.052-.087-.196-.14-.413-.248-.218-.109-1.284-.635-1.48-.707-.196-.073-.339-.109-.482.109-.144.218-.557.707-.683.85-.126.143-.252.163-.47.054-.218-.109-.916-.338-1.745-1.077-.645-.575-1.08-1.286-1.206-1.504-.126-.218-.014-.336.095-.445.098-.098.218-.253.326-.379.109-.126.145-.218.218-.361.072-.144.036-.271-.018-.38-.054-.109-.482-1.163-.661-1.593z" /></svg>
      <span class="absolute left-16 bg-gray-900 text-white px-3 py-1.5 rounded-md text-sm font-bold opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg">WhatsApp Destek</span>
    </a>
  </div>

  <div class="fixed bottom-0 left-0 w-full z-[100] flex md:hidden shadow-[0_-10px_20px_rgba(0,0,0,0.15)]">
    <a href="tel:+902124000013" class="flex-1 bg-blue-600 text-white py-4 flex items-center justify-center gap-2 font-extrabold text-sm active:bg-blue-800 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.864-1.051l-3.215-.536a2.25 2.25 0 0 0-2.15.586l-1.48 1.48a18.04 18.04 0 0 1-7.143-7.143l1.48-1.48a2.25 2.25 0 0 0 .586-2.15l-.536-3.215A2.25 2.25 0 0 0 7.372 2.25H6.002c-1.243 0-2.25 1.007-2.25 2.25Z" /></svg>
      HEMEN ARA
    </a>
    <a href="https://wa.me/902124000013" target="_blank" class="flex-1 bg-[#25D366] text-white py-4 flex items-center justify-center gap-2 font-extrabold text-sm active:bg-green-700 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829zM10.826 6.299c-.198-.444-.405-.453-.591-.462-.152-.007-.327-.008-.501-.008-.175 0-.457.066-.696.326-.239.261-.913.892-.913 2.176s.935 2.523 1.066 2.697c.13.174 1.84 2.808 4.456 3.907 1.838.772 2.28.618 2.671.583.391-.035 1.261-.515 1.435-1.013.174-.499.174-.925.122-1.013-.052-.087-.196-.14-.413-.248-.218-.109-1.284-.635-1.48-.707-.196-.073-.339-.109-.482.109-.144.218-.557.707-.683.85-.126.143-.252.163-.47.054-.218-.109-.916-.338-1.745-1.077-.645-.575-1.08-1.286-1.206-1.504-.126-.218-.014-.336.095-.445.098-.098.218-.253.326-.379.109-.126.145-.218.218-.361.072-.144.036-.271-.018-.38-.054-.109-.482-1.163-.661-1.593z" /></svg>
      WHATSAPP
    </a>
  </div>

</MainLayout>