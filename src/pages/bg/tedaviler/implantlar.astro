---
// BG (Bulgarca) versiyonu için:
// src/pages/bg/tedaviler/implantlar.astro

import MainLayout from '../../../layouts/MainLayout.astro';
import TedaviDoktorlari from '../../../components/TedaviDoktorlari.astro'; // DOKTOR BİLEŞENİ EKLENDİ

// SEO için sayfa başlığı ve açıklaması
const pageTitle = "Лечение с импланти | Оригинални и гарантирани марки | Dental Implant Clinic A Plus";
const pageDescription = "100% оригинални, сертифицирани лечения с импланти Straumann, Bego, Nobel, Medentika и Medigma в Силиври и Чаталджа. Доживотни трайни решения на най-добри цени.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/implant-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/95 via-klinik-koyu/60 to-transparent z-0"></div> 
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <div class="max-w-3xl">
        <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">100% Оригинално и сертифицирано</span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-2xl">
          Трайно решение за липсващи зъби: <br/><span class="text-klinik-yesil">Лечение с импланти</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed drop-shadow-lg">
          Имплантологични решения с титаниеви корени, които са здрави колкото вашите естествени зъби, с доживотна гаранция и по стандартите на A Plus.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/3 prose prose-lg prose-slate max-w-none">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Какво е Имплант?</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Имплантите са изкуствени зъбни корени, изработени от щадящ тъканите титан, които се поставят в челюстната кост, за да възстановят функцията и естетиката на липсващите зъби. Днес това е <strong>най-добрият, най-естественият и най-дълготрайният</strong> известен метод при лечението на липса на зъби.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            В нашата клиника хирургичните процедури се извършват с милиметрична прецизност чрез 3D томография (обемна томография) подкрепена дигитална планировка. По този начин границата на грешка се намалява до нула и времето за възстановяване се съкращава максимално.
          </p>

          <div class="bg-gray-50 rounded-2xl p-8 border-l-4 border-klinik-yesil mb-10">
            <h3 class="text-xl font-bold text-klinik-koyu mb-4">Защо трябва да си поставите имплант?</h3>
            <ul class="space-y-3 text-gray-700 font-medium">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Предпазва съседните зъби:</strong> Няма нужда да изпилявате здравите си съседни зъби, както при лечението с мост.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Спира стопяването на костта:</strong> Предотвратява стопяването на челюстната кост в областта, където е изваден зъбът.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Естествено усещане при дъвчене:</strong> Можете да отхапвате силно и да ядете всичко удобно, също както със собствения си зъб.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Доживотна употреба:</strong> Оригиналните и сертифицирани импланти остават с вас за цял живот при добра грижа.</li>
            </ul>
          </div>

          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Как се прилага лечението с импланти?</h2>
          <div class="space-y-6">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">3D Томография и дигитално планиране</h4>
                <p class="text-gray-600">Дебелината на вашата челюстна кост, местоположението на нервите и костната плътност се изследват подробно с 3D томография. Позицията на импланта се планира с милиметрична точност в дигитална среда.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Хирургична процедура (Поставяне на импланта)</h4>
                <p class="text-gray-600">Под местна упойка (без да усещате никаква болка) изкуственият титаниев корен се поставя в челюстната кост. Често поставянето на един имплант отнема само 15-20 минути.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Заздравяване и Надстройка (Порцелан)</h4>
                <p class="text-gray-600">Изчаква се 2 до 3 месеца имплантът да се слее с челюстната кост. Процесът приключва с поставянето на вашия естетичен порцеланов или циркониев зъб върху интегрирания с костта имплант.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 sticky top-32">
          <img src="/images/implant-kutu.webp" alt="3D Лечение с импланти" class="w-full h-64 object-cover rounded-t-2xl shadow-sm" />
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-b-2xl shadow-xl">
            <h3 class="text-2xl font-bold text-klinik-koyu mb-4">Безплатна Томография и Преглед</h3>
            <p class="text-gray-500 mb-6 text-sm">Разберете безплатно дали вашата костна структура е подходяща за импланти с нашия 3D томографски апарат.</p>
            
            <a href="https://wa.me/902124000013" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#25D366] text-white font-bold py-4 px-6 rounded-xl hover:bg-green-600 transition-colors mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829z" /></svg>
              Получете информация по WhatsApp
            </a>
            <a href="tel:+902124000013" class="w-full flex items-center justify-center gap-2 bg-klinik-koyu text-white font-bold py-4 px-6 rounded-xl hover:bg-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Обадете се в клиниката: +90 212 400 00 13
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-24 bg-[#F8FAFC]">
    <div class="container mx-auto px-4 max-w-7xl">
        <div class="bg-white rounded-[40px] p-8 md:p-16 shadow-xl border border-gray-100 flex flex-col lg:flex-row gap-16 items-start relative overflow-hidden">
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-klinik-yesil/5 rounded-full blur-3xl pointer-events-none"></div>

            <div class="w-full lg:w-1/2 relative z-10">
                <span class="inline-block bg-klinik-turuncu text-white px-4 py-1 rounded-full text-xs font-bold mb-4 tracking-widest uppercase">Прозрачна ценова политика</span>
                <h2 class="text-3xl md:text-4xl font-bold text-[#1E293B] leading-tight mb-6">
                    Предлагаме ви 100% оригинални сертифицирани,<br />
                    <span class="text-[#334155]">гарантирани</span> импланти
                </h2>
                <p class="text-gray-500 mb-8 text-sm md:text-base leading-relaxed">
                    Като Поликлиника за орално и дентално здраве Dental Implant Clinic A Plus, ние ви предлагаме най-достъпните премиум имплантологични решения в Турция с баркод и международен гаранционен паспорт.
                </p>
                
                <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-100">
                  <ul class="space-y-4 text-[#1E293B] font-bold text-sm md:text-base">
                      <li class="flex items-center justify-between border-b border-gray-200 pb-2">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Имплант Straumann</span> 
                        <span class="text-klinik-turuncu">€ 400</span>
                      </li>
                      <li class="flex items-center justify-between border-b border-gray-200 pb-2">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Имплант Nobel Biocare</span> 
                        <span class="text-klinik-turuncu">€ 300</span>
                      </li>
                      <li class="flex items-center justify-between border-b border-gray-200 pb-2">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Имплант Medentika</span> 
                        <span class="text-klinik-turuncu">€ 140</span>
                      </li>
                      <li class="flex items-center justify-between border-b border-gray-200 pb-2">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Имплант Bego</span> 
                        <span class="text-klinik-turuncu">€ 95</span>
                      </li>
                      <li class="flex items-center justify-between">
                        <span class="flex items-center gap-2"><span class="w-2 h-2 bg-klinik-yesil rounded-full"></span> Имплант Medigma</span> 
                        <span class="text-klinik-turuncu">€ 70</span>
                      </li>
                  </ul>
                </div>
                
                <a href="https://wa.me/902124000013" target="_blank" class="inline-flex items-center gap-4 bg-[#212E3D] text-white pl-2 pr-8 py-2 rounded-xl font-bold hover:bg-black transition-all shadow-xl group">
                    <div class="bg-[#5C8AB4] p-3 rounded-lg group-hover:bg-klinik-yesil transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                    </div>
                    Запитване за оригинален продукт
                </a>
            </div>

            <div class="w-full lg:w-1/2 flex flex-col pt-8 lg:pt-0 relative z-10">
                {[
                    { name: 'Имплант Straumann', logo: 'straumann.svg' },
                    { name: 'Имплант Nobel Biocare', logo: 'nobel.svg' },
                    { name: 'Имплант Medentika', logo: 'medentika.svg' },
                    { name: 'Имплант Bego', logo: 'bego.svg' },
                    { name: 'Имплант Medigma', logo: 'medigma.svg' }
                ].map((brand) => (
                    <div class="flex items-center justify-start gap-8 py-6 border-b border-gray-100 last:border-0 hover:bg-gray-50 px-6 rounded-xl transition-colors group">
                        <img src={`/icons/${brand.logo}`} alt={brand.name} class="h-10 md:h-12 w-28 md:w-36 object-contain grayscale group-hover:grayscale-0 transition-all duration-300" />
                        <span class="text-lg md:text-xl font-bold text-[#475569] group-hover:text-klinik-yesil transition-colors">{brand.name}</span>
                    </div>
                ))}
            </div>
        </div>
    </div>
  </section>

  <TedaviDoktorlari tedavi="implantlar" />

  <section class="py-20 bg-white pb-32">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-klinik-koyu mb-4">Често задавани <span class="text-klinik-yesil">въпроси</span></h2>
        <p class="text-gray-600">Това, което нашите пациенти се чудят най-много относно лечението с импланти.</p>
      </div>

      <div class="space-y-4">
        <details class="group bg-gray-50 rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Има ли болка по време или след операцията за поставяне на имплант?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Тъй като процедурата с имплантите се извършва под местна анестезия, по време на хирургическата операция не се усеща абсолютно никаква болка. Леките изтичания, които могат да възникнат след преминаване на ефекта на анестезията, лесно се контролират със стандартни болкоуспокояващи, предписани от нашия лекар.</p>
        </details>

        <details class="group bg-gray-50 rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Има ли риск тялото да отхвърли импланта?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Имплантите се произвеждат от чист титан, който е съвместим с тъканите (биосъвместим). Биологично не е възможно човешкото тяло да произвежда антитела срещу титан и да го отхвърли, както при трансплантации на сърце или бъбреци. При използване на оригинални и сертифицирани продукти успеваемостта е над 98%.</p>
        </details>

        <details class="group bg-gray-50 rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Могат ли да се направят вадене на зъб и имплант в един и същи ден?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Да, с тази техника, която наричаме "Незабавен (Immediate) имплант", ако няма остра инфекция в челюстната ви кост и структурата на костта ви е подходяща, вашият имплант може да бъде поставен в същата кухина в една сесия в момента, в който зъбът ви бъде изваден.</p>
        </details>
      </div>
    </div>
  </section>

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Правна информация</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Този уебсайт е създаден изключително с цел информиране на пациентите, в пълно съответствие с правилата на Министерството на здравеопазването на Република Турция.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Общ кол център: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Последна актуализация: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Редактор: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>

</MainLayout>