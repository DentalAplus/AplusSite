---
// BG (Bulgarca) versiyonu için:
// src/pages/bg/tedaviler/all-on-four.astro

import MainLayout from '../../../layouts/MainLayout.astro';
import TedaviDoktorlari from '../../../components/TedaviDoktorlari.astro'; 

const pathname = Astro.url.pathname;
const pathLang = pathname.split('/')[1]; 
const currentLang = ['tr', 'en', 'de', 'bg'].includes(pathLang) ? pathLang : 'tr'; 

const pageTitle = "Лечение с импланти All On 4 | Фиксирани зъби в един ден | Клиника Yüceler A+";
const pageDescription = "Лечение с импланти All-on-4 при пълна липса на зъби в Силиври и Чаталджа. Сдобийте се с фиксирани, естетични и надеждни зъби само за един ден с 4 импланта.";

---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/all-on-four-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/95 via-klinik-koyu/60 to-transparent z-0"></div> 
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <div class="max-w-3xl">
        <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">Фиксирани зъби в един ден</span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-2xl">
          Бързо решение за пълна липса на зъби: <br/><span class="text-klinik-yesil">Импланти All On 4</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed drop-shadow-lg">
          За нашите пациенти, които са загубили всичките си зъби или са на път да ги загубят, възможност за получаване на фиксирани, естетични и функционални зъби в същия ден само с 4 импланта.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/3 prose prose-lg prose-slate max-w-none">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Какво представлява техниката с импланти All On 4?</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            <strong>All On 4 (Система с четири импланта)</strong> е бърза и изключително надеждна хирургична процедура, прилагана при напълно обеззъбени пациенти или в случаите, когато трябва да бъдат извадени всички зъби. Докато традиционните методи изискват 6 до 8 импланта на челюст за фиксирана протеза, при техниката All On 4 фиксирани зъби се правят за цялата челюст с помощта на <strong>само 4 титаниеви импланта</strong>, поставени под специални ъгли.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            При тази техника се поставят 2 прави импланта в предната част на челюстта и 2 импланта под ъгъл в задната част, за да се избегнат анатомичните кухини (синусната кухина и нервните канали). Най-голямото предимство е, че вашите <strong>временни фиксирани зъби се поставят в същия ден на операцията.</strong> Никога не напускате клиниката без зъби.
          </p>

          <div class="bg-gray-50 rounded-2xl p-8 border-l-4 border-klinik-yesil mb-10">
            <h3 class="text-xl font-bold text-klinik-koyu mb-4">Какви са предимствата на лечението All On 4?</h3>
            <ul class="space-y-3 text-gray-700 font-medium">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Фиксирани зъби в един ден:</strong> Часове след хирургичната процедура се прибирате вкъщи с фиксирани (несваляеми) временни зъби.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Не е необходима сложна хирургия:</strong> Благодарение на разположението под ъгъл, най-често не са необходими допълнителни и скъпи процедури като костна присадка (графт) или синус лифт.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Висок комфорт:</strong> Напълно елиминира раните, говорните нарушения и рефлекса за гадене, причинени от небните (сваляеми) протези.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Икономично:</strong> Тъй като се използват по-малко импланти, е по-рентабилно от традиционните лечения с импланти за цяла челюст.</li>
            </ul>
          </div>

          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Как протича процесът на лечение All On 4?</h2>
          <div class="space-y-6 mb-10">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">3D томография и дигитално планиране</h4>
                <p class="text-gray-600">Първо, челюстната ви кост се сканира с 3D обемна томография. Областите и ъглите, където ще бъдат поставени имплантите, се планират с точност до милиметър в компютърна среда. Взимат се вашите мерки и временните ви зъби се подготвят предварително.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Хирургична процедура и временни зъби</h4>
                <p class="text-gray-600">Под местна анестезия (или по желание със седация) се изваждат останалите проблемни зъби и в същата сесия се поставят 4 импланта в челюстта. Веднага след хирургичната процедура предварително подготвените ви фиксирани временни зъби се завинтват върху имплантите.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Поставяне на постоянни естетични зъби</h4>
                <p class="text-gray-600">Изчаква се средно 3 месеца, за да могат имплантите да се слеят напълно с костта. В края на този период вашите временни зъби се премахват и се поставят вашите постоянни порцеланови или циркониеви зъби, проектирани по най-подходящия за лицето ви начин.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 sticky top-32">
          <img src="/images/all-on-four-kutu.webp" alt="Лечение с импланти All On 4" class="w-full h-64 object-cover rounded-t-2xl shadow-sm" />
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-b-2xl shadow-xl">
            <h3 class="text-2xl font-bold text-klinik-koyu mb-4">Освободете се от небните протези</h3>
            <p class="text-gray-500 mb-6 text-sm">Разберете веднага дали сте подходящи за лечение All On 4 с безплатна 3D томография и преглед от специалист.</p>
            
            <a href="https://wa.me/902124000013" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#25D366] text-white font-bold py-4 px-6 rounded-xl hover:bg-green-600 transition-colors mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829z" /></svg>
              Попитайте за цена по WhatsApp
            </a>
            <a href="tel:+902124000013" class="w-full flex items-center justify-center gap-2 bg-klinik-koyu text-white font-bold py-4 px-6 rounded-xl hover:bg-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Обадете се в клиниката: +90 212 400 00 13
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <TedaviDoktorlari tedavi="all-on-four" />

  <section class="py-20 bg-gray-50 border-t border-gray-100 pb-32">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-klinik-koyu mb-4">Често задавани <span class="text-klinik-yesil">въпроси</span></h2>
        <p class="text-gray-600">Това, което нашите пациенти се чудят най-много относно лечението с импланти All On 4.</p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Болезнена процедура ли е лечението All On 4?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Не, тъй като хирургичната процедура се извършва изцяло под местна анестезия, няма да почувствате никаква болка по време на операцията. Лекото кървене или подуване, които могат да възникнат след процедурата, лесно се преодоляват с рутинни болкоуспокояващи, препоръчани от нашия лекар.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Кой може да си направи лечение All On 4?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Всички лица, които изпитват пълна липса на зъби в челюстната кост, не желаят да използват подвижни (сваляеми) небни протези и нямат системни заболявания, които биха могли да попречат на операцията за поставяне на импланти, могат безопасно да се възползват от това лечение.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Мога ли да ям веднага с временните зъби?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Да, можете да ядете, но е много важно за успеха на импланта да избягвате твърди храни през първия 3-месечен период, който е периодът на сливане на имплантите с костта (осеоинтеграция), и да консумирате само меки храни, препоръчани от вашия лекар. След като постоянните ви зъби бъдат поставени, можете удобно да ядете каквото пожелаете.</p>
        </details>
      </div>
    </div>
  </section>

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Правна информация</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Този уебсайт е създаден изключително с цел информиране на пациентите, в пълно съответствие с правилата на Министерството на здравеопазването на Република Турция.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Общ кол център: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Последна актуализация: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Редактор: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>

</MainLayout>