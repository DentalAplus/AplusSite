---
// BG (Bulgarca) versiyonu için:
// src/pages/bg/tedaviler/estetik-dolgular.astro

import MainLayout from '../../../layouts/MainLayout.astro';
import TedaviDoktorlari from '../../../components/TedaviDoktorlari.astro'; // DOKTOR BİLEŞENİ EKLENDİ

// SEO için sayfa başlığı ve açıklaması
const pageTitle = "Естетична композитна пломба и Бондинг | Клиника Yüceler A+";
const pageDescription = "Лечение с естетична композитна пломба и бондинг в Силиври и Чаталджа. Ние обновяваме старите ви черни пломби с естествени и издръжливи пломби, които идеално пасват на цвета на вашите зъби.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/estetik-dolgu-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/95 via-klinik-koyu/60 to-transparent z-0"></div> 
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <div class="max-w-3xl">
        <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">Естествени и незабележими</span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-2xl">
          Невидими <br/><span class="text-klinik-yesil">Естетични Пломби</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed drop-shadow-lg">
          Обновяваме усмивката ви в една сесия с издръжливи и естетични композитни пломби (бондинг), които са напълно съобразени с цвета на вашите зъби и не съдържат живак.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/3 prose prose-lg prose-slate max-w-none">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Какво е Естетична композитна пломба (Бондинг)?</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Замествайки стари, черни и съдържащи живак амалгамени пломби, <strong>естетичните композитни пломби</strong> са възстановителни материали от ново поколение, които перфектно се адаптират към естествения цвят, пропускливост на светлина и текстура на зъба.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Този метод, използван особено при затваряне на разстояния между предните зъби (диастема), поправяне на счупвания, премахване на обезцветяване или удължаване на дължината на зъбите, се нарича <strong>Бондинг</strong>. Това е превантивно естетично лечение, което създава чудеса в една сесия, без да уврежда зъбната тъкан.
          </p>

          <div class="bg-gray-50 rounded-2xl p-8 border-l-4 border-klinik-yesil mb-10">
            <h3 class="text-xl font-bold text-klinik-koyu mb-4">Какви са предимствата на естетичните пломби?</h3>
            <ul class="space-y-3 text-gray-700 font-medium">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Естествен вид:</strong> Избират се специално за цвета на вашите зъби, като не се разбира отвън, че е пломба.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Предпазва тъканта:</strong> Почиства се само кариесът, няма нужда от отваряне на допълнителни кухини както при старите пломби.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Бързо решение:</strong> Завършва се в една сесия чрез втвърдяване със специални лъчи и може да се използва веднага.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Безопасно и Здравословно:</strong> Не съдържа живак или вредни тежки метали и е напълно щадящо за тъканите.</li>
            </ul>
          </div>

          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Процес на приложение (Стъпка по стъпка)</h2>
          <div class="space-y-6 mb-10">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Почистване и Подготовка</h4>
                <p class="text-gray-600">Кариесът или старата проблемна пломба се почистват под местна упойка. Повърхността на зъба се набраздява със специални гелове на микро ниво, за да може композитният материал да прилепне.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Метод на наслояване (Layering)</h4>
                <p class="text-gray-600">Като се имитират естествения зъбен емайл и цветовете на дентина, избраният композитен материал се обработва върху зъба слой по слой и му се придава анатомична форма.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Осветяване и Безупречно полиране</h4>
                <p class="text-gray-600">Материалът се втвърдява със специални LED лъчи. На последния етап се прилага отличен процес на полиране за премахване на грапавините и улавяне на естествения блясък на зъба.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 sticky top-32">
          <img src="/images/estetik-dolgu-kutu.webp" alt="Естетична Композитна Пломба Преди След" class="w-full h-64 object-cover rounded-t-2xl shadow-sm" />
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-b-2xl shadow-xl">
            <h3 class="text-2xl font-bold text-klinik-koyu mb-4">Сбогувайте се с черните пломби</h3>
            <p class="text-gray-500 mb-6 text-sm">Свържете се с нас, за да заменим вашите стари черни пломби с естетични бели пломби или да поправим счупванията на предните ви зъби.</p>
            
            <a href="https://wa.me/902124000013" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#25D366] text-white font-bold py-4 px-6 rounded-xl hover:bg-green-600 transition-colors mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829z" /></svg>
              Попитайте за цена по WhatsApp
            </a>
            <a href="tel:+902124000013" class="w-full flex items-center justify-center gap-2 bg-klinik-koyu text-white font-bold py-4 px-6 rounded-xl hover:bg-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Обадете се в клиниката: +90 212 400 00 13
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <TedaviDoktorlari tedavi="estetik-dolgular" />

  <section class="py-20 bg-gray-50 border-t border-gray-100 pb-32">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-klinik-koyu mb-4">Често задавани <span class="text-klinik-yesil">въпроси</span></h2>
        <p class="text-gray-600">Нещата, които се чудят относно процедурите с естетични пломби и бондинг.</p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Колко издръжливи са естетичните (композитни) пломби?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Благодарение на развиващата се технология, композитните пломби от ново поколение са поне толкова устойчиви на дъвкателни сили, колкото старите амалгамени пломби. При правилно полиране и редовна грижа за устната кухина могат да се използват безопасно в продължение на много години.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Трябва ли да сменя черните си (амалгамени) пломби?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Адаптацията на ръбовете на амалгамените пломби може да се влоши с течение на времето и под тях да се образуват скрити кариеси. В допълнение, поради тежките метали, които съдържат, и неестетичния черен вид, подмяната им със здрави композитни пломби е стандартен и здравословен подход днес.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Колко време отнема лечението с бондинг (естетика на предни зъби)?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Процесът на бондинг обикновено се завършва в една сесия (30-60 минути), в зависимост от размера на увреждането или празнината в зъба. Има случаи, при които дори не се изисква упойка и пациентът напуска клиниката веднага с естетичен резултат.</p>
        </details>
      </div>
    </div>
  </section>

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Правна информация</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Този уебсайт е създаден изключително с цел информиране на пациентите, в пълно съответствие с правилата на Министерството на здравеопазването на Република Турция.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Общ кол център: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Последна актуализация: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Редактор: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>

</MainLayout>