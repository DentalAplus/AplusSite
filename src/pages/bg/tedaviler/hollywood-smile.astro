---
// BG (Bulgarca) versiyonu için:
// src/pages/bg/tedaviler/hollywood-smile.astro

import MainLayout from '../../../layouts/MainLayout.astro';
import TedaviDoktorlari from '../../../components/TedaviDoktorlari.astro'; // DOKTOR BİLEŞENİ EKLENDİ

// SEO için sayfa başlığı ve açıklaması
const pageTitle = "Дизайн на усмивката Hollywood Smile | Клиника Yüceler A+";
const pageDescription = "Персонализирано лечение Hollywood Smile (Дизайн на усмивката) в Силиври и Чаталджа. Сдобийте се с безупречната, бяла усмивка на вашите мечти с цирконий, ламина и розова естетика.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hollywood-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/95 via-klinik-koyu/60 to-transparent z-0"></div> 
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <div class="max-w-3xl">
        <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">Безупречна хармония и естетика</span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-2xl">
          Усмивката на вашите мечти: <br/><span class="text-klinik-yesil">Hollywood Smile</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed drop-shadow-lg">
          Сдобийте се с безупречна и бяла усмивка, която най-добре подхожда на чертите на лицето, структурата на устните и характера ви, проектирана според правилата на златното сечение.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/3 prose prose-lg prose-slate max-w-none">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Какво е Hollywood Smile?</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            <strong>Hollywood Smile</strong> е цялостна концепция за естетична дентална медицина, която носи името си от безупречните, бели и симетрични усмивки на холивудските звезди. Не се занимава само с цвета и подредбата на зъбите; също така се занимава с хармонията на златното сечение на нивата на венците, формата на устните и всички черти на лицето.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Вместо еднократно лечение; това е персонализирано произведение на изкуството, при което много приложения като <strong>порцеланови ламинатни фасети (ламина), циркониеви коронки, избелване на зъби и розова естетика (корекция на венците)</strong> се използват заедно според нуждите на пациента.
          </p>

          <div class="bg-gray-50 rounded-2xl p-8 border-l-4 border-klinik-yesil mb-10">
            <h3 class="text-xl font-bold text-klinik-koyu mb-4">Защо трябва да си направите Hollywood Smile?</h3>
            <ul class="space-y-3 text-gray-700 font-medium">
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Хармония на златното сечение:</strong> Вашата усмивка е направена 100% съвместима с чертите на лицето ви.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Повишаване на самоувереността:</strong> Здравите и бели зъби възстановяват увереността ви в социалния живот.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Млад и динамичен външен вид:</strong> Чрез осигуряване на опора на устните, бръчките на устните намаляват, създавайки по-младежко изражение.</li>
              <li class="flex items-center gap-3"><svg class="w-5 h-5 text-klinik-yesil" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>Симетрични венци:</strong> Прекомерно видимите венци при усмивка (Gummy Smile) са идеално скрити.</li>
            </ul>
          </div>

          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Как протича процесът на дигитален дизайн на усмивката?</h2>
          <div class="space-y-6 mb-10">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Студийни снимки и дигитален анализ</h4>
                <p class="text-gray-600">Първо се правят професионални снимки и видеоклипове на вашето лице. Вашите цифрови отпечатъци се вземат с 3D интраорални скенери и се прехвърлят в програми за дизайн, за да се определи формата на зъбите, която най-добре подхожда на характера на вашето лице.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Mock-Up (Проба на усмивката)</h4>
                <p class="text-gray-600">Вашите нови зъби, проектирани на компютър, се изпробват в устата ви със специален материал, без да се прави нищо по зъбите ви (Mock-up). Така виждате как ще изглеждате, когато лечението приключи, и можете да се намесите в дизайна, ако желаете.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-klinik-koyu text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
              <div>
                <h4 class="text-xl font-bold text-klinik-koyu mb-2">Приложение на леченията и Финал</h4>
                <p class="text-gray-600">Първо, ако има асиметрия на венците, те се коригират с лазер. След това вашите E-Max ламина или циркониеви коронки се подготвят в лабораторията според плана и се нанасят върху зъбите ви със специални медицински лепила.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 sticky top-32">
          <img src="/images/hollywood-kutu.webp" alt="Дизайн на усмивката Hollywood Smile" class="w-full h-64 object-cover rounded-t-2xl shadow-sm" />
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-b-2xl shadow-xl">
            <h3 class="text-2xl font-bold text-klinik-koyu mb-4">Нека проектираме вашата персонализирана усмивка</h3>
            <p class="text-gray-500 mb-6 text-sm">Нека заедно да видим великолепната промяна след лечението с безплатен дигитален анализ на усмивката.</p>
            
            <a href="https://wa.me/902124000013" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#25D366] text-white font-bold py-4 px-6 rounded-xl hover:bg-green-600 transition-colors mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829z" /></svg>
              Получете информация по WhatsApp
            </a>
            <a href="tel:+902124000013" class="w-full flex items-center justify-center gap-2 bg-klinik-koyu text-white font-bold py-4 px-6 rounded-xl hover:bg-black transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Обадете се в клиниката: +90 212 400 00 13
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <TedaviDoktorlari tedavi="gulus-tasarimi" />

  <section class="py-20 bg-gray-50 border-t border-gray-100 pb-32">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-klinik-koyu mb-4">Често задавани <span class="text-klinik-yesil">въпроси</span></h2>
        <p class="text-gray-600">Нещата, които се чудят относно дизайна на усмивката Hollywood Smile.</p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Може ли Hollywood Smile да се направи на всеки?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Да, може да се приложи при всички възрастни, които искат да имат естетична усмивка. Това не е стандартен шаблон, а напълно персонализирано лечение, проектирано от нулата според пропорциите на лицето и структурата на устата ви.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Колко време отнема лечението с дизайн на усмивката?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Процесът варира в зависимост от обхвата на необходимите лечения. В случаите, когато не се изискват интервенции на венците или импланти и ще се прави само ламина или цирконий, резултатите се получават средно от 5 до 7 дни.</p>
        </details>

        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
          <summary class="flex items-center justify-between font-bold text-lg text-klinik-koyu">
            Страх ме е, че зъбите ми няма да изглеждат естествено, ще изглеждат ли изкуствени?
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <p class="text-gray-600 mt-4 leading-relaxed">Материали като E-Max и цирконий, използвани в нашата клиника, имат много висока светлопропускливост. Нашата цел е не само да направим бели зъби; е да произведем естествени зъби, подходящи за вашия цвят на кожата, възраст и характер, така че никой да не разбере, че са фасети.</p>
        </details>
      </div>
    </div>
  </section>

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Правна информация</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Този уебсайт е създаден изключително с цел информиране на пациентите, в пълно съответствие с правилата на Министерството на здравеопазването на Република Турция.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Общ кол център: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Последна актуализация: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Редактор: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>

</MainLayout>