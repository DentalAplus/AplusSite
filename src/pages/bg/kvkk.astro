import MainLayout from '../../layouts/MainLayout.astro';

// SEO için sayfa başlığı ve açıklaması
const pageTitle = "KVKK Информационен текст и нашите политики | Клиника Yüceler A+";
const pageDescription = "Dental Implant Clinic A Plus Закон за защита на личните данни (KVKK) информационен текст, политики за обработка и унищожаване на данни.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-20 bg-klinik-koyu overflow-hidden">
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-center text-center">
      <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">Нашите корпоративни политики</span>
      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-4">
        Защита на личните данни (KVKK)
      </h1>
      <p class="text-gray-300 max-w-2xl">
        Сигурността и поверителността на вашите лични данни са под нашата правна гаранция. Можете да разгледате всички наши правни текстове и политики в разделите по-долу.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white min-h-[60vh]">
    <div class="container mx-auto px-4 max-w-6xl">
      
      <div class="flex flex-col md:flex-row border-b border-gray-200 mb-10 overflow-x-auto no-scrollbar">
        <button class="tab-btn whitespace-nowrap active px-6 py-4 font-bold text-klinik-yesil border-b-2 border-klinik-yesil transition-colors" data-target="tab-aydinlatma">
          KVKK Информационен текст
        </button>
        <button class="tab-btn whitespace-nowrap px-6 py-4 font-bold text-gray-500 hover:text-klinik-yesil transition-colors" data-target="tab-politika">
