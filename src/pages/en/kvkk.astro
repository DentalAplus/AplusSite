---
import MainLayout from '../../layouts/MainLayout.astro';

// SEO için sayfa başlığı ve açıklaması
const pageTitle = "KVKK Aydınlatma Metni ve Politikalarımız | Yüceler A+ Klinik";
const pageDescription = "Dental Implant Clinic A Plus kişisel verilerin korunması kanunu (KVKK) aydınlatma metni, veri işleme ve imha politikaları.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-20 bg-klinik-koyu overflow-hidden">
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-center text-center">
      <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">Kurumsal Politikalarımız</span>
      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-4">
        Kişisel Verilerin Korunması (KVKK)
      </h1>
      <p class="text-gray-300 max-w-2xl">
        Kişisel verilerinizin güvenliği ve gizliliği yasal güvencemiz altındadır. Tüm hukuki metinlerimizi ve politikalarımızı aşağıdaki sekmelerden inceleyebilirsiniz.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white min-h-[60vh]">
    <div class="container mx-auto px-4 max-w-6xl">
      
      <div class="flex flex-col md:flex-row border-b border-gray-200 mb-10 overflow-x-auto no-scrollbar">
