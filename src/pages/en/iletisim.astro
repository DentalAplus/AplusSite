                <svg class="w-6 h-6 text-klinik-turuncu shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <p class="text-gray-600 font-medium">Piri Mehmet Pasa Mah. Yemenciler Sok. No:13<br/>Next to Halkbank, Silivri / Istanbul</p>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-6 h-6 text-klinik-yesil shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <p class="text-gray-600 font-medium">Mon - Sat: <span class="font-bold text-klinik-koyu">09:00 - 19:00</span></p>
              </div>
            </div>
            
            <a href="/en/clinics/silivri" class="mt-auto w-full text-center bg-gray-50 hover:bg-klinik-yesil hover:text-white text-klinik-koyu border border-gray-200 font-bold py-3 rounded-xl transition-colors">View Branch</a>
          </div>
        </div>

        <div class="bg-white rounded-[2rem] shadow-xl border border-gray-100 overflow-hidden flex flex-col hover:shadow-2xl transition-shadow duration-300">
          <div class="h-64 bg-gray-200 w-full relative">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3004.499465276856!2d28.45660887655717!3d41.14545151096641!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14b545176c8fa55b%3A0x119928693d1b7112!2sDental%20Implant%20Clinic%20Trakya!5e0!3m2!1str!2str!4v1772116306949!5m2!1str!2str" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
          <div class="p-8 flex flex-col grow">
            <h3 class="text-2xl font-extrabold text-klinik-koyu mb-4 border-b border-gray-100 pb-4">Catalca Clinic</h3>
            
            <div class="space-y-4 mb-8">
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-klinik-turuncu shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
