        </div>
        <h3 class="font-bold text-gray-800 text-lg mb-2">WhatsApp Consultation</h3>
        <p class="text-xl font-extrabold text-[#25D366]">Send a Message</p>
        <span class="text-sm text-gray-500 mt-2">Free X-ray evaluation</span>
      </a>

      <a href="mailto:info@dentalimplanttrakya.com" class="flex flex-col items-center text-center p-8 rounded-2xl bg-white hover:bg-klinik-yesil/10 hover:border-klinik-yesil/30 border border-transparent transition-all duration-300 group">
        <div class="w-16 h-16 bg-klinik-yesil/20 text-klinik-yesil rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </div>
        <h3 class="font-bold text-gray-800 text-lg mb-2">Corporate E-Mail</h3>
