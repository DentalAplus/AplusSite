                            <option value="İmplant">Implant</option>
                            <option value="Hollywood Smile">Hollywood Smile</option>
                            <option value="All on Four">All on Four</option>
                            <option value="Zirkonyum">Zirconium</option>
                            <option value="Porselen">Porcelain</option>
                            <option value="Laminate Veneer">Laminate Veneer</option>
                            <option value="Dolgu">Filling</option>
                            <option value="Kanal Tedavisi">Root Canal Treatment</option>
                            <option value="Diş Beyazlatma">Teeth Whitening</option>
                            <option value="Diş Temizleme">Teeth Cleaning</option>
                            <option value="Diş Çekimi">Tooth Extraction</option>
                            <option value="Ortodonti">Orthodontics</option>
                            <option value="Periodontoloji">Periodontology</option>
                            <option value="Çocuk Muayene">Pediatric Examination</option>
                        </select>
