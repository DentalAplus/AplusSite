                <svg class="w-6 h-6 text-klinik-yesil shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <p class="text-gray-600 font-medium">Mon - Sat: <span class="font-bold text-klinik-koyu">09:00 - 19:00</span></p>
              </div>
            </div>

            <a href="/en/clinics/catalca" class="mt-auto w-full text-center bg-gray-50 hover:bg-klinik-yesil hover:text-white text-klinik-koyu border border-gray-200 font-bold py-3 rounded-xl transition-colors">View Branch</a>
