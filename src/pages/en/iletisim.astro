                <button type="submit" class="w-full bg-klinik-koyu text-white font-extrabold py-5 rounded-xl hover:bg-klinik-yesil hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex justify-center items-center gap-2 text-lg mt-4">
                    Send Request
                    <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
                </button>
            </form>

            <script id='wf_anal' src='https://crm.zohopublic.eu/crm/WebFormAnalyticsServeServlet?&tw=75b31b79dcecf67669f9ba84b95bdc41c1c6767082c1659bd21b32616c57306f'></script>

        </div>
