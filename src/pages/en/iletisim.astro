---
import MainLayout from '../../layouts/MainLayout.astro';

// SEO Settings
const pageTitle = "Contact & Appointment | Dental Implant Clinic A Plus";
const pageDescription = "Contact us immediately to make an appointment at our Silivri and Catalca branches, learn dental treatment prices, or get online consultation.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-20 md:py-28 bg-klinik-koyu overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/iletisim-banner.webp')] bg-cover bg-center opacity-20 mix-blend-overlay"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-klinik-koyu"></div>
    
    <div class="container mx-auto px-4 max-w-4xl relative z-10 text-center">
      <div class="inline-flex items-center justify-center p-3 bg-white/10 rounded-full mb-6 backdrop-blur-md border border-white/20 shadow-xl">
        <svg class="w-6 h-6 text-klinik-turuncu mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" /></svg>
        <span class="text-white font-bold tracking-wide text-sm">We Are Ready to Listen</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6 leading-tight drop-shadow-lg">
        Get in Touch <span class="text-klinik-yesil">With Us</span>
      </h1>
      <p class="text-gray-300 text-lg md:text-xl font-light">
        Our expert patient consultants are at your service 24/7 for appointments, online consultations, or treatment planning.
      </p>
    </div>
  </section>

  <section class="py-12 bg-gray-50 relative z-20 -mt-8 mx-4 md:mx-auto max-w-6xl rounded-3xl shadow-xl border border-gray-100">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 p-4">
      
      <a href="tel:+902124000013" class="flex flex-col items-center text-center p-8 rounded-2xl bg-white hover:bg-blue-50 hover:border-blue-200 border border-transparent transition-all duration-300 group">
        <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        </div>
        <h3 class="font-bold text-gray-800 text-lg mb-2">Central Call Line</h3>
        <p class="text-2xl font-extrabold text-blue-600">+90 212 400 00 13</p>
        <span class="text-sm text-gray-500 mt-2">Call for all appointments</span>
      </a>

      <a href="https://wa.me/902124000013" target="_blank" class="flex flex-col items-center text-center p-8 rounded-2xl bg-white hover:bg-green-50 hover:border-green-200 border border-transparent transition-all duration-300 group relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-[#25D366] text-white text-[10px] font-bold px-3 py-1 rounded-bl-lg">24/7 ACTIVE</div>
        <div class="w-16 h-16 bg-green-100 text-[#25D366] rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
