            <div class="absolute top-4 left-4 bg-klinik-koyu text-white text-xs font-bold px-3 py-1 rounded-md shadow-lg">MAIN BRANCH</div>
          </div>
          <div class="p-8 flex flex-col grow">
            <h3 class="text-2xl font-extrabold text-klinik-koyu mb-4 border-b border-gray-100 pb-4">Silivri Clinic</h3>
            
            <div class="space-y-4 mb-8">
