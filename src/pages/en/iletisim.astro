      <div class="bg-white p-8 md:p-12 rounded-[2rem] shadow-2xl border border-gray-100 relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-klinik-yesil/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-klinik-turuncu/10 rounded-full blur-3xl"></div>
        
        <div class="relative z-10">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-bold text-klinik-koyu mb-3">Online <span class="text-klinik-yesil">Appointment Request</span></h2>
                <p class="text-gray-600">Fill out the form, and our expert patient consultants will get back to you as soon as possible.</p>
            </div>

            <form action='https://crm.zoho.eu/crm/WebToLeadForm' name='WebToLeads821351000022557341' method='POST' accept-charset='UTF-8' class="space-y-6">
                
                <input type='text' style='display:none;' name='xnQsjsdp' value='a836530a32ce19fae67b1aec795737d9bbcfb548068b4df9970e4a9b456c7615'>
                <input type='hidden' name='zc_gad' id='zc_gad' value=''>
                <input type='text' style='display:none;' name='xmIwtLD' value='0f489dd25dd3185d56c26b2aca17fe74d5f8bfd50674c575e783ab4ab1271ec1ef6764ef7730c476b63db28a30c9d009'>
                <input type='text' style='display:none;' name='actionType' value='TGVhZHM='>
                <input type='text' style='display:none;' name='returnURL' value='https://www.dentalimplanttrakya.com/en/thank-you'> 
                <input type='text' style='display:none;' name='aG9uZXlwb3Q' value=''>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Full Name *</label>
                        <input type="text" name="Last Name" placeholder="Full Name" required maxlength="80" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-klinik-yesil focus:border-klinik-yesil outline-none transition-all bg-gray-50 focus:bg-white" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Mobile Phone *</label>
                         <input type="tel" name="Mobile" placeholder="+90 XXX XXX XX XX" required maxlength="30" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-klinik-yesil focus:border-klinik-yesil outline-none transition-all bg-gray-50 focus:bg-white" />
                    </div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Preferred Clinic</label>
                        <select name="LEADCF5" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-klinik-yesil focus:border-klinik-yesil outline-none transition-all bg-gray-50 focus:bg-white text-gray-700 appearance-none">
                            <option value="-None-">- Doesn't Matter / I Want to Consult -</option>
                            <option value="Silivri">Silivri</option>
                            <option value="Çatalca">Catalca</option>
                            <option value="Büyükçekmece">Buyukcekmece</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Interested Services</label>
                        <select name="LEADCF2" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-klinik-yesil focus:border-klinik-yesil outline-none transition-all bg-gray-50 focus:bg-white text-gray-700 appearance-none">
