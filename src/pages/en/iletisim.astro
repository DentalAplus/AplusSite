                </div>

                <div class="flex items-start gap-3 mt-2">
                    <input type="checkbox" id="kvkk" required class="mt-1 w-4 h-4 text-klinik-yesil bg-gray-100 border-gray-300 rounded focus:ring-klinik-yesil focus:ring-2 cursor-pointer">
