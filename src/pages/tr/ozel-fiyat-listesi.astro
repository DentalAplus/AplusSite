---
import MainLayout from '../../layouts/MainLayout.astro';

// SEO ayarları
const pageTitle = "Size Özel Tedavi Fiyat Listesi | Yüceler A+ Klinik";
const pageDescription = "Dental Implant Clinic A Plus - Hastalarımıza özel güncel diş tedavi, implant ve estetik kaplama fiyat listemiz.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-20 md:py-28 bg-klinik-koyu overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/fiyat-listesi-banner.webp')] bg-cover bg-center opacity-20 mix-blend-overlay"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-klinik-koyu"></div>
    
    <div class="container mx-auto px-4 max-w-4xl relative z-10 text-center">
      <div class="inline-flex items-center justify-center p-3 bg-white/10 rounded-full mb-6 backdrop-blur-md border border-white/20 shadow-xl">
        <svg class="w-6 h-6 text-klinik-turuncu mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
