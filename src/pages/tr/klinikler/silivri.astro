---
import MainLayout from '../../../layouts/MainLayout.astro';
import UygulayanDoktorlar from '../../../components/UygulayanDoktorlar.astro';

const pageTitle = "Silivri Merkez Kliniği | Dental Implant Clinic A Plus";
const pageDescription = "Silivri'deki modern diş kliniğimizde uzman hekim kadromuz, uluslararası sağlık turizmi yetki belgemiz ve anlaşmalı kurumlarımızla hizmetinizdeyiz.";
---

<MainLayout title={pageTitle}>
  
  <section class="relative py-24 md:py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/silivri-klinik-banner.webp');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/95 via-klinik-koyu/60 to-transparent z-0"></div> 
    
    <div class="container mx-auto px-4 max-w-6xl relative z-10 flex flex-col items-start text-left">
      <div class="max-w-3xl">
        <span class="inline-block bg-klinik-yesil text-white px-4 py-1 rounded-full text-sm font-bold mb-4 tracking-widest uppercase">Merkez Şube</span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-white drop-shadow-2xl">
          Silivri <span class="text-klinik-yesil">Kliniğimiz</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed drop-shadow-lg">
          Uluslararası standartlarda, en ileri dijital diş hekimliği teknolojileri ve uzman kadromuzla Silivri'nin merkezinde hizmetinizdeyiz.
        </p>
      </div>
    </div>
  </section>

  <section class="py-10 bg-white border-b border-gray-100 shadow-sm relative z-20 -mt-4 rounded-t-3xl overflow-hidden">
    <div class="container mx-auto px-4 max-w-6xl flex flex-col items-center">
      
      <div class="mb-8 text-center flex flex-col items-center">
         <img src="/icons/saglik-turizmi.svg" alt="Uluslararası Sağlık Turizmi Yetki Belgesi" class="w-80 md:w-[450px] lg:w-[500px] h-auto object-contain drop-shadow-md hover:scale-105 transition-transform duration-300" style="aspect-ratio: 3/2;" title="Uluslararası Sağlık Turizmi Yetki Belgesi" />
         <p class="text-sm text-gray-500 font-bold mt-4 uppercase tracking-widest">Uluslararası Sağlık Turizmi Yetki Belgesi</p>
      </div>

      <div class="w-full relative overflow-hidden group mt-4 marquee-mask">
        <div class="flex animate-marquee w-fit">
            
            <div class="flex items-center gap-12 md:gap-20 py-2 px-6 shrink-0">
                <img src="/icons/saglik-bakanligi.svg" alt="T.C. Sağlık Bakanlığı Onaylı" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
                <img src="/icons/safe-tourism.svg" alt="Safe Tourism Sertifikası" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
                <img src="/icons/heal-in-turkey.svg" alt="Heal In Turkey" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
                <img src="/icons/iso-9001.svg" alt="ISO 9001" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
                <img src="/icons/tbd-logo.svg" alt="Türk Dişhekimleri Birliği" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
            </div>

            <div class="flex items-center gap-12 md:gap-20 py-2 px-6 shrink-0" aria-hidden="true">
                <img src="/icons/saglik-bakanligi.svg" alt="T.C. Sağlık Bakanlığı Onaylı" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
                <img src="/icons/safe-tourism.svg" alt="Safe Tourism Sertifikası" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
                <img src="/icons/heal-in-turkey.svg" alt="Heal In Turkey" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
                <img src="/icons/iso-9001.svg" alt="ISO 9001" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
                <img src="/icons/tbd-logo.svg" alt="Türk Dişhekimleri Birliği" class="h-10 md:h-14 w-auto object-contain hover:grayscale transition-all duration-300 cursor-pointer" />
            </div>

        </div>
      </div>
      
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-12 items-start">
        
        <div class="w-full lg:w-1/2">
          <h2 class="text-3xl font-bold text-klinik-koyu mb-6">Bizimle İletişime Geçin</h2>
          <p class="text-gray-600 mb-8">Randevu almak, fiyat bilgisi sormak veya tedavilerimiz hakkında bilgi almak için aşağıdaki formu doldurabilirsiniz. Uzman hasta danışmanlarımız size en kısa sürede dönüş yapacaktır.</p>
          
          <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100">
            <form id="silivriContactForm" class="space-y-5">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1">Adınız Soyadınız</label>
                  <input type="text" placeholder="Adınız Soyadınız" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-klinik-yesil focus:border-klinik-yesil outline-none transition-all bg-gray-50 focus:bg-white" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1">Telefon Numaranız</label>
                  <input type="tel" placeholder="05XX XXX XX XX" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-klinik-yesil focus:border-klinik-yesil outline-none transition-all bg-gray-50 focus:bg-white" />
                </div>
              </div>
              
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">E-Posta Adresiniz (İsteğe Bağlı)</label>
                <input type="email" placeholder="ornek@mail.com" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-klinik-yesil focus:border-klinik-yesil outline-none transition-all bg-gray-50 focus:bg-white" />
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Mesajınız / Şikayetiniz</label>
                <textarea rows="4" placeholder="Nasıl yardımcı olabiliriz?" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-klinik-yesil focus:border-klinik-yesil outline-none transition-all bg-gray-50 focus:bg-white resize-none"></textarea>
              </div>

              <button type="submit" class="w-full bg-klinik-koyu text-white font-bold py-4 rounded-xl hover:bg-klinik-yesil transition-colors flex justify-center items-center gap-2">
                Mesajı Gönder
                <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
              </button>
              <p class="text-xs text-gray-400 text-center mt-2">Kişisel verileriniz KVKK kapsamında korunmaktadır.</p>
            </form>
          </div>
        </div>

        <div class="w-full lg:w-1/2 flex flex-col gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100">
            <h3 class="font-bold text-lg text-klinik-koyu mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-klinik-turuncu" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              Kliniğimize Ulaşın
            </h3>
            
            <div class="w-full overflow-hidden rounded-xl bg-gray-200 h-[400px] md:h-[450px]">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1504.6067096645398!2d28.246487108343714!3d41.07378442133168!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14b5377f0d2c0b47%3A0x7d6f5f3e498c1d5b!2sDental%20Implant%20Clinic%20A%20Plus!5e0!3m2!1str!2str!4v1710000000000" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>

            <div class="mt-4">
              <a href="https://www.google.com/maps/dir/?api=1&destination=41.073784,28.247681" target="_blank" class="flex items-center justify-center gap-2 w-full py-3.5 bg-klinik-yesil text-white rounded-xl font-bold hover:bg-klinik-koyu transition-all duration-300 shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                Navigasyonu Başlat (Yol Tarifi Al)
              </a>
              <p class="text-[11px] text-gray-400 text-center mt-2 font-medium">Konumu telefonunuza göndermek için tıklayın</p>
            </div>

            <div class="mt-6 space-y-5">
              
              <div class="flex items-start gap-4">
                <div class="bg-klinik-yesil/10 p-3 rounded-lg text-klinik-yesil shrink-0">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-semibold mb-1">Adres</p>
                  <p class="text-klinik-koyu font-medium leading-relaxed">
                    Piri Mehmet Paşa Mah. Yemenciler Sok. No:13<br/>
                    Halkbankası Yanı, Silivri / İstanbul
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="bg-klinik-yesil/10 p-3 rounded-lg text-klinik-yesil shrink-0">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-semibold mb-1">Telefon</p>
                  <a href="tel:+902124000013" class="text-lg font-bold text-klinik-koyu hover:text-klinik-turuncu transition-colors">+90 212 400 00 13</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="bg-klinik-yesil/10 p-3 rounded-lg text-klinik-yesil shrink-0">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-semibold mb-1">E-posta</p>
                  <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-base font-bold text-klinik-koyu hover:text-klinik-turuncu transition-colors">bilgi@dentalimplanttrakya.com</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="bg-klinik-yesil/10 p-3 rounded-lg text-klinik-yesil shrink-0">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-semibold mb-1">Çalışma Saatleri</p>
                  <p class="text-klinik-koyu font-medium">Pzt - Cmt: 09:00 - 19:00</p>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-16 bg-white border-t border-gray-100">
    <div class="container mx-auto px-4 max-w-6xl text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold text-klinik-koyu mb-2">Anlaşmalı <span class="text-klinik-turuncu">Kurumlar</span></h2>
      <p class="text-gray-500 mb-10 text-sm md:text-base">Vakıf ve sandık mensuplarına özel avantajlı diş tedavisi hizmetleri sunuyoruz.</p>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-items-center opacity-80 hover:opacity-100 transition-opacity">
        <img src="/icons/halkbank.svg" alt="Halkbank Vakfı" class="h-12 md:h-16 object-contain hover:scale-105 transition-transform" />
        <img src="/icons/yapikredi.svg" alt="Yapı Kredi Emekli Sandığı" class="h-12 md:h-16 object-contain hover:scale-105 transition-transform" />
        <img src="/icons/aksandik.svg" alt="Akbank Sandığı" class="h-12 md:h-16 object-contain hover:scale-105 transition-transform" />
        <img src="/icons/ziraatbank.svg" alt="Ziraat Bankası Vakfı" class="h-12 md:h-16 object-contain hover:scale-105 transition-transform" />
      </div>
    </div>
  </section>

  <UygulayanDoktorlar filtre_tipi="klinik" filtre_degeri="silivri" />

  <footer class="bg-klinik-koyu text-white py-12 border-t-4 border-klinik-turuncu mt-auto">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start gap-8">
      <div class="max-w-2xl">
        <h3 class="text-klinik-turuncu font-bold text-lg mb-3">Yasal Bilgilendirme</h3>
        <p class="text-sm text-gray-300 leading-relaxed">
          Bu web sitesi, T.C. Sağlık Bakanlığı "Sağlık Hizmetlerinde Tanıtım ve Bilgilendirme Faaliyetleri Hakkında Yönetmelik" kurallarına tam uyumlu olarak, yalnızca hastaları bilgilendirme amacıyla hazırlanmıştır.
        </p>
      </div>
      <div class="text-sm text-gray-400 text-left md:text-right">
        <p class="mb-2 text-white font-semibold">Dental Implant Clinic A Plus</p>
        <p class="mb-1">Ortak Çağrı Merkezi: <span class="text-klinik-turuncu">+90 212 400 00 13</span></p>
        <div class="mt-4 p-3 bg-gray-800 rounded-lg inline-block text-left border border-gray-700">
          <p class="mb-1 text-xs">Son Güncelleme: <span class="text-white font-bold">21.02.2026</span></p>
          <p class="text-xs">Editör: <a href="mailto:bilgi@dentalimplanttrakya.com" class="text-klinik-turuncu hover:underline">bilgi@dentalimplanttrakya.com</a></p>
        </div>
      </div>
    </div>
  </footer>

  <div class="h-16 md:hidden block"></div>
  
  <div class="hidden md:flex flex-col fixed bottom-8 left-8 z-[100] gap-4">
    <a href="tel:+902124000013" class="bg-blue-600 text-white p-4 rounded-full shadow-2xl hover:scale-110 hover:bg-blue-700 transition-all duration-300 flex items-center justify-center group relative">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.864-1.051l-3.215-.536a2.25 2.25 0 0 0-2.15.586l-1.48 1.48a18.04 18.04 0 0 1-7.143-7.143l1.48-1.48a2.25 2.25 0 0 0 .586-2.15l-.536-3.215A2.25 2.25 0 0 0 7.372 2.25H6.002c-1.243 0-2.25 1.007-2.25 2.25Z" /></svg>
      <span class="absolute left-16 bg-gray-900 text-white px-3 py-1.5 rounded-md text-sm font-bold opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg">Hemen Ara</span>
    </a>
    <a href="https://wa.me/902124000013" target="_blank" class="bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 hover:bg-green-600 transition-all duration-300 flex items-center justify-center group relative">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829zM10.826 6.299c-.198-.444-.405-.453-.591-.462-.152-.007-.327-.008-.501-.008-.175 0-.457.066-.696.326-.239.261-.913.892-.913 2.176s.935 2.523 1.066 2.697c.13.174 1.84 2.808 4.456 3.907 1.838.772 2.28.618 2.671.583.391-.035 1.261-.515 1.435-1.013.174-.499.174-.925.122-1.013-.052-.087-.196-.14-.413-.248-.218-.109-1.284-.635-1.48-.707-.196-.073-.339-.109-.482.109-.144.218-.557.707-.683.85-.126.143-.252.163-.47.054-.218-.109-.916-.338-1.745-1.077-.645-.575-1.08-1.286-1.206-1.504-.126-.218-.014-.336.095-.445.098-.098.218-.253.326-.379.109-.126.145-.218.218-.361.072-.144.036-.271-.018-.38-.054-.109-.482-1.163-.661-1.593z" /></svg>
      <span class="absolute left-16 bg-gray-900 text-white px-3 py-1.5 rounded-md text-sm font-bold opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg">WhatsApp Destek</span>
    </a>
  </div>

  <div class="fixed bottom-0 left-0 w-full z-[100] flex md:hidden shadow-[0_-10px_20px_rgba(0,0,0,0.15)]">
    <a href="tel:+902124000013" class="flex-1 bg-blue-600 text-white py-4 flex items-center justify-center gap-2 font-extrabold text-sm active:bg-blue-800 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.864-1.051l-3.215-.536a2.25 2.25 0 0 0-2.15.586l-1.48 1.48a18.04 18.04 0 0 1-7.143-7.143l1.48-1.48a2.25 2.25 0 0 0 .586-2.15l-.536-3.215A2.25 2.25 0 0 0 7.372 2.25H6.002c-1.243 0-2.25 1.007-2.25 2.25Z" /></svg>
      HEMEN ARA
    </a>
    <a href="https://wa.me/902124000013" target="_blank" class="flex-1 bg-[#25D366] text-white py-4 flex items-center justify-center gap-2 font-extrabold text-sm active:bg-green-700 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M12.031 21.033c-1.56 0-3.084-.42-4.42-1.216l-.317-.189-3.284.861.876-3.203-.207-.331a9.022 9.022 0 0 1-1.378-4.755C3.301 7.155 7.215 3.24 12.031 3.24c2.33 0 4.519.907 6.166 2.555 1.648 1.648 2.556 3.837 2.556 6.167 0 4.914-3.915 8.829-8.73 8.829zM10.826 6.299c-.198-.444-.405-.453-.591-.462-.152-.007-.327-.008-.501-.008-.175 0-.457.066-.696.326-.239.261-.913.892-.913 2.176s.935 2.523 1.066 2.697c.13.174 1.84 2.808 4.456 3.907 1.838.772 2.28.618 2.671.583.391-.035 1.261-.515 1.435-1.013.174-.499.174-.925.122-1.013-.052-.087-.196-.14-.413-.248-.218-.109-1.284-.635-1.48-.707-.196-.073-.339-.109-.482.109-.144.218-.557.707-.683.85-.126.143-.252.163-.47.054-.218-.109-.916-.338-1.745-1.077-.645-.575-1.08-1.286-1.206-1.504-.126-.218-.014-.336.095-.445.098-.098.218-.253.326-.379.109-.126.145-.218.218-.361.072-.144.036-.271-.018-.38-.054-.109-.482-1.163-.661-1.593z" /></svg>
      WHATSAPP
    </a>
  </div>

</MainLayout>

<style>
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); } 
  }
  
  .animate-marquee {
    display: flex;
    width: fit-content; 
    animation: marquee 30s linear infinite;
  }
  
  .group:hover .animate-marquee {
    animation-play-state: paused;
  }

  .marquee-mask {
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }
</style>