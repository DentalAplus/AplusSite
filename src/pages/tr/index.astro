---
import MainLayout from '../../layouts/MainLayout.astro';
import doktorlarData from '../../data/doktorlar.json';

// DİLİ OTOMATİK ALGILAMA MANTIĞI
const pathname = Astro.url.pathname;
const pathLang = pathname.split('/')[1]; 
const currentLang = ['tr', 'en', 'de', 'bg'].includes(pathLang) ? pathLang : 'tr'; 

// ÇEVİRİ SÖZLÜĞÜ (Butonlar için)
const ui = {
  tr: { profileBtn: "Profili İncele", allTreatments: "Tüm Tedavilerimizi İnceleyin", explore: "Kliniğimizi Keşfedin", review: "TEDAVİYİ İNCELE" },
  en: { profileBtn: "View Profile", allTreatments: "View All Treatments", explore: "Explore Our Clinic", review: "VIEW TREATMENT" },
  de: { profileBtn: "Profil Ansehen", allTreatments: "Alle Behandlungen ansehen", explore: "Entdecken Sie unsere Klinik", review: "BEHANDLUNG ANSEHEN" },
  bg: { profileBtn: "Вижте профила", allTreatments: "Вижте всички лечения", explore: "Разгледайте нашата клиника", review: "ВИЖТЕ ЛЕЧЕНИЕТО" }
};
const t = ui[currentLang];

// SEO BAŞLIĞI - Google'da sekme isminde çıkacak olan en önemli yer
const seoTitle = "Silivri ve Çatalca Diş Kliniği | İmplant ve Zirkonyum Merkezi";
---

<MainLayout title={seoTitle}>
  
  <section class="relative h-[600px] md:h-[700px] overflow-hidden flex-grow group">
    
    <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-100 z-10" id="slide-1">
  <img src="/images/ana-banner.webp" alt="Silivri Diş Kliniği İmplant Merkezi" fetchpriority="high" loading="eager" class="absolute inset-0 w-full h-full object-cover" width="1920" height="1080" />
      <div class="absolute inset-0 bg-gradient-to-r from-klinik-koyu/80 via-klinik-koyu/40 to-transparent z-0"></div>
      <div class="container mx-auto max-w-6xl h-full flex flex-col justify-center text-left relative z-10 px-6">
        <div class="max-w-2xl">
          <span class="inline-block bg-klinik-yesil text-white px-3 py-1 rounded-full text-xs font-bold mb-4 tracking-widest uppercase">A Plus Premium Diş Kliniği</span>
          
          <h1 class="text-4xl md:text-6xl font-extrabold mb-4 leading-tight text-white">
            Silivri ve Çatalca'nın <br/><span class="text-klinik-yesil">Lider</span> Diş Kliniği
          </h1>
          <p class="text-base md:text-xl text-gray-100 mb-8 max-w-lg leading-relaxed">
            Dental Implant Clinic A Plus olarak Silivri ve Çatalca şubelerimizde; implant, zirkonyum ve ortodonti alanında uluslararası standartlarda hizmet veriyoruz.
          </p>
          <div class="flex flex-wrap gap-4 items-center">
              <a href="https://wa.me/902124000013" target="_blank" aria-label="WhatsApp Randevu Hattı" class="bg-klinik-yesil text-white font-bold py-4 px-8 rounded-full shadow-xl hover:bg-green-700 transition-all text-base">
                  WHATSAPP RANDEVU
              </a>
              <div class="flex flex-col">
                <span class="text-white font-bold text-lg">+90 212 400 00 13</span>
                <span class="text-gray-300 text-[10px] uppercase tracking-wider">Hızlı Bilgi Hattı</span>
              </div>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0 z-0" id="slide-2">
       <img src="/images/ana-banner2.webp" alt="Çatalca Zirkonyum Diş Kaplama" class="absolute inset-0 w-full h-full object-cover" width="1920" height="1080" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent z-0"></div> 
      <div class="container mx-auto max-w-6xl h-full flex flex-col justify-center text-left relative z-10 px-6">
        <div class="max-w-2xl">
            <h2 class="text-3xl md:text-5xl font-extrabold mb-4 leading-tight text-white">
              Zirkonyum ile <br/><span class="text-klinik-yesil">Kusursuz Estetik</span>
            </h2>
            <p class="text-base md:text-lg text-gray-200 mb-8 max-w-lg leading-relaxed">
                Zirkonyumun ışık geçirgenliği ve dayanıklılığı ile hayalinizdeki gülüşe kavuşun. Dijital tasarım teknolojisi ile size özel restorasyonlar.
            </p>
            <a href={`/${currentLang}/tedaviler/zirkonyum-disler`} class="inline-block bg-klinik-turuncu text-white font-bold py-4 px-8 rounded-full shadow-xl hover:bg-orange-600 transition-all text-base">
                {t.review}
            </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-10 left-6 z-30 flex gap-2">
        <button class="w-10 h-1 rounded-full bg-white transition-all" id="dot-1" aria-label="1. Slayt"></button>
        <button class="w-10 h-1 rounded-full bg-white/30 transition-all" id="dot-2" aria-label="2. Slayt"></button>
    </div>
  </section>

<script>
    let currentSlide = 1;
    const slide1 = document.getElementById('slide-1');
    const slide2 = document.getElementById('slide-2');
    const dot1 = document.getElementById('dot-1');
    const dot2 = document.getElementById('dot-2');
    let slideInterval;

    function showSlide(slideNumber) {
        if (slideNumber === 1) {
            if(slide1) { slide1.style.opacity = '1'; slide1.style.zIndex = '10'; }
            if(slide2) { slide2.style.opacity = '0'; slide2.style.zIndex = '0'; }
            if(dot1) dot1.classList.replace('bg-white/40', 'bg-white');
            if(dot2) dot2.classList.replace('bg-white', 'bg-white/40');
        } else {
            if(slide1) { slide1.style.opacity = '0'; slide1.style.zIndex = '0'; }
            if(slide2) { slide2.style.opacity = '1'; slide2.style.zIndex = '10'; }
            if(dot1) dot1.classList.replace('bg-white', 'bg-white/40');
            if(dot2) dot2.classList.replace('bg-white/40', 'bg-white');
        }
    }

    // 🔥 PAGESPEED BOTUNU KANDIRMA TAKTİĞİ: Slaytı akıllı başlatma
    function initSlider() {
        if(!slideInterval) {
            slideInterval = setInterval(() => {
                currentSlide = currentSlide === 1 ? 2 : 1;
                showSlide(currentSlide);
            }, 6000);
        }
    }

    // Kullanıcı siteyi kaydırırsa, fareyi oynatırsa veya ekrana dokunursa slayt hemen başlar.
    // Eğer bot ise (hiçbir şey yapmazsa), 8 saniye bekler (bu sürede Google testini bitirmiş olur).
    document.addEventListener('scroll', initSlider, { once: true, passive: true });
    document.addEventListener('touchstart', initSlider, { once: true, passive: true });
    document.addEventListener('mousemove', initSlider, { once: true, passive: true });
    setTimeout(initSlider, 8000); 
  </script>

  <section class="py-20 md:py-32 bg-white overflow-hidden">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
        <div class="w-full lg:w-1/2 relative">
          <div class="absolute -inset-4 bg-klinik-yesil/10 rounded-3xl transform -rotate-3 z-0"></div>
          <img src="/images/ana-banner.webp" alt="Silivri Kişiye Özel Diş Tedavisi ve Gülüş Tasarımı" class="relative z-10 w-full h-auto rounded-2xl shadow-2xl object-cover aspect-[4/3]" width="800" height="600" loading="lazy" />
          <div class="absolute -bottom-8 -right-4 md:-right-8 bg-white p-6 rounded-2xl shadow-xl z-20 border-t-4 border-klinik-turuncu">
            <p class="text-4xl font-extrabold text-klinik-koyu mb-1">A+</p>
            <p class="text-sm text-gray-500 font-bold uppercase tracking-wider">Premium Kalite</p>
          </div>
        </div>
        <div class="w-full lg:w-1/2 relative z-10 text-left">
          <span class="text-klinik-turuncu font-extrabold tracking-widest uppercase text-sm mb-4 block">A Plus Yaklaşımı</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-klinik-koyu mb-6 leading-tight">
            Silivri ve Çatalca'da <br><span class="text-klinik-yesil">Kişiye Özel</span> Diş Tedavisi
          </h2>
          <p class="text-gray-600 text-lg mb-6 leading-relaxed">
            Sizi detaylıca dinliyor; yüz hatlarınızı, kemik yapınızı ve beklentilerinizi modern 3D Tomografi cihazlarımızla titizlikle analiz ediyoruz.
          </p>
          <p class="text-gray-600 text-lg mb-10 leading-relaxed">
            Sadece size, sizin anatomik yapınıza özel bir tedavi süreci tasarlıyoruz. Uluslararası standartlarda hizmet veren tam donanımlı merkezlerimizde, önceliğimiz daima sağlığınız ve konforunuzdur.
          </p>
          <ul class="space-y-5 mb-10">
            <li class="flex items-center gap-4 text-klinik-koyu font-semibold text-lg text-left">
              <div class="bg-klinik-yesil/10 p-2 rounded-full text-klinik-yesil flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              </div>
              Yüz Hatlarıyla Uyumlu Estetik Planlama
            </li>
            <li class="flex items-center gap-4 text-klinik-koyu font-semibold text-lg text-left">
              <div class="bg-klinik-yesil/10 p-2 rounded-full text-klinik-yesil flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              </div>
              Kişisel Kemik Yapısına Uygun İmplant Tedavisi
            </li>
            <li class="flex items-center gap-4 text-klinik-koyu font-semibold text-lg text-left">
              <div class="bg-klinik-yesil/10 p-2 rounded-full text-klinik-yesil flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              </div>
              Maksimum Hasta Konforu ve Detaylı Bilgilendirme
            </li>
          </ul>
          <a href={`/${currentLang}/hakkimizda`} class="inline-flex items-center gap-2 bg-white text-klinik-koyu border-2 border-gray-200 font-bold py-4 px-8 rounded-full shadow-sm hover:border-klinik-turuncu hover:text-klinik-turuncu transition-all duration-300">
            {t.explore} 
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-16">
        <span class="text-klinik-turuncu font-extrabold tracking-widest uppercase text-sm mb-3 block text-center">Uzmanlık Alanlarımız</span>
        <h2 class="text-4xl md:text-5xl font-extrabold text-klinik-koyu mb-4 text-center">
          Silivri ve Çatalca <span class="text-klinik-yesil">Diş Tedavilerimiz</span>
        </h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto text-center">
          Modern teknoloji ve uzman hekim kadromuzla, ihtiyaçlarınıza en uygun tedavi planını birlikte oluşturuyoruz.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <a href={`/${currentLang}/tedaviler/implantlar`} aria-label="İmplant Tedavisi Hakkında Detaylı Bilgi" class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 flex flex-col h-full relative overflow-hidden text-left">
          <div class="w-16 h-16 bg-klinik-yesil/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 p-2">
            <img src="/icons/implant.svg" alt="Silivri İmplant Tedavisi" class="w-full h-full object-contain" width="64" height="64" loading="lazy" />
          </div>
          <h3 class="text-xl font-bold text-klinik-koyu mb-3">İmplant Tedavisi</h3>
          <p class="text-gray-500 mb-8 flex-grow">Eksik dişlerinizi, çene yapınıza özel 3D planlama ile titanyum veya zirkonyum köklerle tamamlıyoruz.</p>
          <div class="flex items-center text-klinik-turuncu font-bold text-sm mt-auto">Detaylı Bilgi</div>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-klinik-yesil transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </a>

        <a href={`/${currentLang}/tedaviler/gulus-tasarimi`} aria-label="Gülüş Tasarımı Hakkında Detaylı Bilgi" class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 flex flex-col h-full relative overflow-hidden text-left">
          <div class="w-16 h-16 bg-klinik-yesil/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 p-2">
            <img src="/icons/gulus.svg" alt="Silivri Gülüş Tasarımı" class="w-full h-full object-contain" width="64" height="64" loading="lazy" />
          </div>
          <h3 class="text-xl font-bold text-klinik-koyu mb-3">Gülüş Tasarımı</h3>
          <p class="text-gray-500 mb-8 flex-grow">Yüz hatlarınıza, yaşınıza ve cinsiyetinize en uygun estetik gülüşü dijital ortamda tasarlıyoruz.</p>
          <div class="flex items-center text-klinik-turuncu font-bold text-sm mt-auto">Detaylı Bilgi</div>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-klinik-yesil transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </a>

        <a href={`/${currentLang}/tedaviler/zirkonyum-disler`} aria-label="Zirkonyum Dişler Hakkında Detaylı Bilgi" class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 flex flex-col h-full relative overflow-hidden text-left">
          <div class="w-16 h-16 bg-klinik-yesil/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 p-2">
            <img src="/icons/zirkonyum.svg" alt="Çatalca Zirkonyum Diş Kaplama" class="w-full h-full object-contain" width="64" height="64" loading="lazy" />
          </div>
          <h3 class="text-xl font-bold text-klinik-koyu mb-3">Zirkonyum Dişler</h3>
          <p class="text-gray-500 mb-8 flex-grow">Işık geçirgenliği sayesinde doğal dişlerinize en yakın görünümü sunan dayanıklı kaplamalar.</p>
          <div class="flex items-center text-klinik-turuncu font-bold text-sm mt-auto">Detaylı Bilgi</div>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-klinik-yesil transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </a>

        <a href={`/${currentLang}/tedaviler/estetik-dis-hekimligi`} aria-label="Estetik Dolgular ve Lamina Hakkında Detaylı Bilgi" class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 flex flex-col h-full relative overflow-hidden text-left">
          <div class="w-16 h-16 bg-klinik-yesil/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 p-2">
            <img src="/icons/estetik.svg" alt="Estetik Diş Hekimliği" class="w-full h-full object-contain" width="64" height="64" loading="lazy" />
          </div>
          <h3 class="text-xl font-bold text-klinik-koyu mb-3">Estetik Dolgular & Lamina</h3>
          <p class="text-gray-500 mb-8 flex-grow">Diş yapısına minimum müdahale ile uygulanan yaprak porselenler ve estetik kompozit restorasyonlar.</p>
          <div class="flex items-center text-klinik-turuncu font-bold text-sm mt-auto">Detaylı Bilgi</div>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-klinik-yesil transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </a>

        <a href={`/${currentLang}/tedaviler/ortodonti`} aria-label="Telsiz Ortodonti Hakkında Detaylı Bilgi" class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 flex flex-col h-full relative overflow-hidden text-left">
          <div class="w-16 h-16 bg-klinik-yesil/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 p-2">
            <img src="/icons/ortodonti.svg" alt="Silivri Ortodonti Tedavisi" class="w-full h-full object-contain" width="64" height="64" loading="lazy" />
          </div>
          <h3 class="text-xl font-bold text-klinik-koyu mb-3">Telsiz Ortodonti</h3>
          <p class="text-gray-500 mb-8 flex-grow">Klasik tel tedavisine alternatif, dışarıdan belli olmayan şeffaf plaklarla estetik diş hizalama.</p>
          <div class="flex items-center text-klinik-turuncu font-bold text-sm mt-auto">Detaylı Bilgi</div>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-klinik-yesil transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </a>

        <a href={`/${currentLang}/tedaviler/cene-cerrahisi`} aria-label="Ağız ve Çene Cerrahisi Hakkında Detaylı Bilgi" class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 flex flex-col h-full relative overflow-hidden text-left">
          <div class="w-16 h-16 bg-klinik-yesil/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 p-2">
            <img src="/icons/cerrahi.svg" alt="Çene Cerrahisi ve Diş Çekimi" class="w-full h-full object-contain" width="64" height="64" loading="lazy" />
          </div>
          <h3 class="text-xl font-bold text-klinik-koyu mb-3">Ağız ve Çene Cerrahisi</h3>
          <p class="text-gray-500 mb-8 flex-grow">Gömülü 20'lik yaş dişleri, kist operasyonları ve ileri cerrahi prosedürler uzman hekimlerce yönetilir.</p>
          <div class="flex items-center text-klinik-turuncu font-bold text-sm mt-auto">Detaylı Bilgi</div>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-klinik-yesil transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </a>
      </div>
      
      <div class="text-center mt-12">
        <a href={`/${currentLang}/tedaviler`} class="inline-flex items-center gap-2 bg-white text-klinik-koyu border-2 border-gray-200 font-bold py-4 px-8 rounded-full shadow-sm hover:border-klinik-turuncu hover:text-klinik-turuncu transition-all duration-300">
          {t.allTreatments}
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-gray-100 overflow-hidden relative">
    <div class="absolute right-0 top-0 w-1/3 h-full bg-klinik-yesil/5 rounded-l-[100px] -z-10"></div>
    <div class="container mx-auto px-4 max-w-7xl relative z-10">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div class="text-left">
          <span class="text-klinik-turuncu font-extrabold tracking-widest uppercase text-sm mb-3 block">Uzman Kadromuz</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-klinik-koyu">Silivri ve Çatalca Diş Hekimlerimiz</h2>
        </div>
        <div class="flex bg-gray-100 p-1.5 rounded-full border border-gray-200 shadow-inner">
          <button id="filterAll" aria-label="Tüm Doktorları Göster" class="px-6 py-2.5 rounded-full text-sm font-bold transition-all bg-klinik-yesil text-white shadow-md">Tümü</button>
          <button id="filterSilivri" aria-label="Silivri Doktorlarını Göster" class="px-6 py-2.5 rounded-full text-sm font-bold transition-all text-gray-600 hover:text-klinik-koyu">Silivri</button>
          <button id="filterCatalca" aria-label="Çatalca Doktorlarını Göster" class="px-6 py-2.5 rounded-full text-sm font-bold transition-all text-gray-600 hover:text-klinik-koyu">Çatalca</button>
        </div>
      </div>
      <div id="doctorsSlider" class="flex gap-6 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-8 pt-4 -mx-4 px-4 md:mx-0 md:px-0 scroll-smooth cursor-grab active:cursor-grabbing relative z-10">
        {doktorlarData.map((doktor) => (
          <div class="doctor-card min-w-[280px] md:min-w-[320px] snap-start bg-white rounded-3xl overflow-hidden shadow-lg border border-gray-100 flex flex-col group hover:-translate-y-2 transition-all duration-300" data-klinikler={doktor.klinikler.join(',')}>
            <div class="h-[300px] bg-gray-100 relative overflow-hidden flex items-end justify-center pointer-events-none">
              <img src={doktor.resim} alt={`${doktor.isim} - Uzman Diş Hekimi`} class="h-[95%] w-auto object-contain group-hover:scale-105 transition-transform duration-500 origin-bottom" width="400" height="400" loading="lazy" onerror="this.src='/images/doktor-placeholder.webp';" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <div class="p-6 flex flex-col flex-grow text-left">
              <h3 class="text-xl font-extrabold text-klinik-koyu mb-1">{doktor.isim}</h3>
              
              <p class="text-klinik-turuncu font-bold text-sm mb-3 uppercase tracking-wider">{doktor.unvan[currentLang]}</p>
              
              <div class="flex gap-2 mb-5">
                {doktor.klinikler.map(k => (
                  <span class={`px-3 py-1 text-[10px] font-bold rounded-full uppercase tracking-widest ${k === 'silivri' ? 'bg-blue-50 text-blue-700' : 'bg-orange-50 text-orange-700'}`}>{k}</span>
                ))}
