---
// src/components/Header.astro
import doktorlarData from '../data/doktorlar.json';

// 1. DİLİ OTOMATİK ALGILAMA MANTIĞI
const pathname = Astro.url.pathname;
const pathLang = pathname.split('/')[1]; 
const currentLang = ['tr', 'en', 'de', 'bg'].includes(pathLang) ? pathLang : 'tr'; 

// 2. HARİKA ZEKİ DİL YÖNLENDİRİCİSİ (Aynı sayfada kalmayı sağlar)
const getLangLink = (targetLang) => {
  const parts = pathname.split('/').filter(Boolean);
  if (parts.length > 0 && ['tr', 'en', 'de', 'bg'].includes(parts[0])) {
    parts[0] = targetLang;
    return '/' + parts.join('/');
  }
  return `/${targetLang}`;
};

// 3. MENÜ SÖZLÜĞÜ (4 DİL İÇİN - TEDAVİLER EKLENDİ)
const ui = {
  tr: { 
    home: "Ana Sayfa", treatments: "Diş Tedavileri", docs: "Hekimlerimiz", silivriDocs: "Silivri Hekimleri", catalcaDocs: "Çatalca Hekimleri", clinics: "Kliniklerimiz", silivri: "Silivri Şubesi", catalca: "Çatalca Şubesi", about: "Hakkımızda", contact: "İletişim",
    // Tedavi Çevirileri
    t_whitening: "Diş Beyazlatma", t_aesthetic: "Estetik Diş Hekimliği", t_zirconium: "Zirkonyum Dişler", t_emax: "E-Max & Empress Porselen", t_lamina: "Porselen Lamina Dişler", t_inley: "Inley ve Onley Dolgular", t_filling: "Estetik Dolgular", t_hollywood: "Hollywood Smile", t_smile: "Gülüş Tasarımı", t_ortho: "Ortodonti (Şeffaf Plak & Tel)", t_implant: "Implant Tedavisi", t_surgery: "Ağız ve Çene Cerrahisi", t_all4: "All On 4 İmplantlar", t_all6: "All On 6 İmplantlar", t_perio: "Diş Eti Tedavileri (Periodontoloji)", t_pedo: "Çocuk Diş Hekimliği (Pedodonti)"
  },
  en: { 
    home: "Home", treatments: "Treatments", docs: "Our Doctors", silivriDocs: "Silivri Doctors", catalcaDocs: "Catalca Doctors", clinics: "Our Clinics", silivri: "Silivri Branch", catalca: "Catalca Branch", about: "About Us", contact: "Contact",
    // Tedavi Çevirileri
    t_whitening: "Teeth Whitening", t_aesthetic: "Aesthetic Dentistry", t_zirconium: "Zirconium Crowns", t_emax: "E-Max & Empress", t_lamina: "Porcelain Laminate Veneers", t_inley: "Inlays and Onlays", t_filling: "Aesthetic Fillings", t_hollywood: "Hollywood Smile", t_smile: "Smile Design", t_ortho: "Orthodontics (Invisalign & Braces)", t_implant: "Implant Treatment", t_surgery: "Oral & Maxillofacial Surgery", t_all4: "All On 4 Implants", t_all6: "All On 6 Implants", t_perio: "Gum Treatments (Periodontology)", t_pedo: "Pediatric Dentistry (Pedodontics)"
  },
  de: { 
    home: "Startseite", treatments: "Behandlungen", docs: "Unsere Ärzte", silivriDocs: "Silivri Ärzte", catalcaDocs: "Catalca Ärzte", clinics: "Unsere Kliniken", silivri: "Silivri Filiale", catalca: "Catalca Filiale", about: "Über Uns", contact: "Kontakt",
    // Tedavi Çevirileri
    t_whitening: "Zahnaufhellung (Bleaching)", t_aesthetic: "Ästhetische Zahnheilkunde", t_zirconium: "Zirkonium-Kronen", t_emax: "E-Max & Empress", t_lamina: "Porzellan-Laminat-Veneers", t_inley: "Inlays und Onlays", t_filling: "Ästhetische Füllungen", t_hollywood: "Hollywood Smile", t_smile: "Lächeln-Design", t_ortho: "Kieferorthopädie (Invisalign & Spangen)", t_implant: "Implantatbehandlung", t_surgery: "Mund-, Kiefer- und Gesichtschirurgie", t_all4: "All-On-4 Implantate", t_all6: "All-On-6 Implantate", t_perio: "Zahnfleischbehandlungen (Parodontologie)", t_pedo: "Kinderzahnheilkunde (Pedodontie)"
  },
  bg: { 
    home: "Начало", treatments: "Лечения", docs: "Нашите лекари", silivriDocs: "Лекари в Силиври", catalcaDocs: "Лекари в Чаталджа", clinics: "Нашите клиники", silivri: "Клон Силиври", catalca: "Клон Чаталджа", about: "За нас", contact: "Контакт",
    // Tedavi Çevirileri
    t_whitening: "Избелване на зъби", t_aesthetic: "Естетична дентална медицина", t_zirconium: "Циркониеви коронки", t_emax: "E-Max и Empress", t_lamina: "Порцеланови ламинатни фасети", t_inley: "Инлеи и онлеи", t_filling: "Естетични пломби", t_hollywood: "Холивудска усмивка", t_smile: "Дизайн на усмивката", t_ortho: "Ортодонтия (Алайнери и брекети)", t_implant: "Имплантологично лечение", t_surgery: "Орална и лицево-челюстна хирургия", t_all4: "Импланти All-On-4", t_all6: "Импланти All-On-6", t_perio: "Лечение на венци (Пародонтология)", t_pedo: "Детска дентална медицина (Педодонтия)"
  }
};
const t = ui[currentLang]; 

// 4. DOKTORLARI ŞUBEYE GÖRE FİLTRELEME
const silivriDoktorlari = doktorlarData.filter(doktor => doktor.klinikler.includes('silivri'));
const catalcaDoktorlari = doktorlarData.filter(doktor => doktor.klinikler.includes('catalca'));
---

<header class="bg-white shadow-md sticky top-0 z-50 border-b border-gray-100 relative">
  <div class="container mx-auto px-2 md:px-4 py-3 md:py-4 flex justify-between items-center">
    
    <a href={`/${currentLang}`} aria-label="Ana Sayfa" class="flex-shrink-0 transition-transform duration-300 hover:scale-105 z-50 mr-2 xl:mr-4">
      <img src="/images/LOGONEW4.svg" alt="Dental Implant Clinic A Plus Logo" class="h-10 lg:h-12 w-auto max-w-[150px] lg:max-w-[200px] object-contain" width="200" height="48" />
    </a>
    
    <nav class="hidden lg:flex flex-1 justify-center items-center gap-2 xl:gap-5 font-semibold text-gray-700 text-[13px] xl:text-sm whitespace-nowrap">
      
      <a href={`/${currentLang}`} class="hover:text-klinik-turuncu transition-colors">{t.home}</a>

      <div class="relative group py-2">
        <button aria-label="Tedaviler Menüsü" class="hover:text-klinik-turuncu transition-colors flex items-center gap-1">
          {t.treatments}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 xl:h-4 xl:w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <ul class="absolute left-0 top-full mt-2 w-64 bg-white border border-gray-100 shadow-xl rounded-lg py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 max-h-96 overflow-y-auto whitespace-normal">
          <li><a href={`/${currentLang}/tedaviler/dis-beyazlatma`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_whitening}</a></li>
          <li><a href={`/${currentLang}/tedaviler/estetik-dis-hekimligi`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_aesthetic}</a></li>
          <li><a href={`/${currentLang}/tedaviler/zirkonyum-disler`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_zirconium}</a></li>
          <li><a href={`/${currentLang}/tedaviler/empress-porselen`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_emax}</a></li>
          <li><a href={`/${currentLang}/tedaviler/porselen-lamina`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_lamina}</a></li>
          <li><a href={`/${currentLang}/tedaviler/inley-onley`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_inley}</a></li>
          <li><a href={`/${currentLang}/tedaviler/estetik-dolgular`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_filling}</a></li>
          <li><a href={`/${currentLang}/tedaviler/hollywood-smile`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_hollywood}</a></li>
          <li><a href={`/${currentLang}/tedaviler/gulus-tasarimi`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_smile}</a></li>
          <li><a href={`/${currentLang}/tedaviler/ortodonti`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_ortho}</a></li>
          <li><a href={`/${currentLang}/tedaviler/implantlar`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_implant}</a></li>
          <li><a href={`/${currentLang}/tedaviler/cene-cerrahisi`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_surgery}</a></li>
          <li><a href={`/${currentLang}/tedaviler/all-on-four`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_all4}</a></li>
          <li><a href={`/${currentLang}/tedaviler/all-on-six`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_all6}</a></li>
          <li><a href={`/${currentLang}/tedaviler/periodontoloji`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_perio}</a></li>
          <li><a href={`/${currentLang}/tedaviler/pedodonti`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.t_pedo}</a></li>
        </ul>
      </div>

      <div class="relative group py-2">
        <button aria-label="Hekimlerimiz Menüsü" class="hover:text-klinik-turuncu transition-colors flex items-center gap-1">
          {t.docs}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 xl:h-4 xl:w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        
        <ul class="absolute left-0 top-full mt-2 w-64 bg-white border border-gray-100 shadow-xl rounded-lg py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 whitespace-normal">
          <li class="relative group/silivri">
            <button aria-label="Silivri Hekimleri Menüsü" class="w-full text-left px-4 py-3 hover:bg-gray-50 flex justify-between items-center text-klinik-koyu font-bold transition-colors">
              {t.silivriDocs}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
            <ul class="absolute left-full top-0 ml-1 w-72 bg-white border border-gray-100 shadow-xl rounded-lg py-2 opacity-0 invisible group-hover/silivri:opacity-100 group-hover/silivri:visible transition-all duration-300 z-50 max-h-[75vh] overflow-y-auto">
              {silivriDoktorlari.map(doktor => (
                <li>
                  <a href={`/${currentLang}/doktorlar/${doktor.id}`} aria-label={`${doktor.isim} Profiline Git`} class="block px-4 py-2 hover:bg-gray-50 transition-colors border-b border-gray-50 last:border-0">
                    <span class="font-bold text-klinik-koyu">{doktor.isim}</span><br>
                    <span class="text-[11px] font-bold text-gray-500 uppercase tracking-wider">{doktor.unvan[currentLang]}</span>
                  </a>
                </li>
              ))}
            </ul>
          </li>

          <li class="relative group/catalca">
            <button aria-label="Çatalca Hekimleri Menüsü" class="w-full text-left px-4 py-3 hover:bg-gray-50 flex justify-between items-center text-klinik-koyu font-bold transition-colors">
              {t.catalcaDocs}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
            <ul class="absolute left-full top-0 ml-1 w-72 bg-white border border-gray-100 shadow-xl rounded-lg py-2 opacity-0 invisible group-hover/catalca:opacity-100 group-hover/catalca:visible transition-all duration-300 z-50 max-h-[75vh] overflow-y-auto">
              {catalcaDoktorlari.map(doktor => (
                <li>
                  <a href={`/${currentLang}/doktorlar/${doktor.id}`} aria-label={`${doktor.isim} Profiline Git`} class="block px-4 py-2 hover:bg-gray-50 transition-colors border-b border-gray-50 last:border-0">
                    <span class="font-bold text-klinik-koyu">{doktor.isim}</span><br>
                    <span class="text-[11px] font-bold text-gray-500 uppercase tracking-wider">{doktor.unvan[currentLang]}</span>
                  </a>
                </li>
              ))}
            </ul>
          </li>
        </ul>
      </div>

      <div class="relative group py-2">
        <button aria-label="Kliniklerimiz Menüsü" class="hover:text-klinik-turuncu transition-colors flex items-center gap-1">
          {t.clinics}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 xl:h-4 xl:w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <ul class="absolute left-0 top-full mt-2 w-48 bg-white border border-gray-100 shadow-xl rounded-lg py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 whitespace-normal">
          <li><a href={`/${currentLang}/klinikler/silivri`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.silivri}</a></li>
          <li><a href={`/${currentLang}/klinikler/catalca`} class="block px-4 py-2 hover:bg-gray-50 hover:text-klinik-turuncu">{t.catalca}</a></li>
        </ul>
      </div>

      <a href={`/${currentLang}/hakkimizda`} class="hover:text-klinik-turuncu transition-colors">{t.about}</a>
      <a href={`/${currentLang}/kvkk`} class="hover:text-klinik-turuncu transition-colors">KVKK</a>
      <a href={`/${currentLang}/iletisim`} class="hover:text-klinik-turuncu transition-colors">{t.contact}</a>
    </nav>

    <div class="flex items-center gap-2 xl:gap-4 z-50">
      
      <div class="hidden xl:flex items-center gap-2 border-r border-gray-200 pr-3">
        <a href="https://www.instagram.com/dentaltrakya/" aria-label="Instagram Sayfamız" target="_blank" class="text-gray-400 hover:text-[#E1306C] transition-colors" title="Instagram">
          <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 xl:w-5 xl:h-5"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.facebook.com/DentalimplantClinicAplus/" aria-label="Facebook Sayfamız" target="_blank" class="text-gray-400 hover:text-[#1877F2] transition-colors" title="Facebook">
          <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 xl:w-5 xl:h-5"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.youtube.com/channel/UCmO0LxeR_kzjsptJpzEGvqw" aria-label="YouTube Sayfamız" target="_blank" class="text-gray-400 hover:text-[#FF0000] transition-colors" title="YouTube">
          <svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 xl:w-6 xl:h-6"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>

      <div class="relative group hidden lg:block pr-1 xl:pr-2">
        <button aria-label="Dil Seçimi" class="flex items-center gap-1 font-extrabold text-klinik-koyu hover:text-klinik-turuncu transition-colors text-xs xl:text-sm uppercase">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 xl:w-4 xl:h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
          {currentLang}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <ul class="absolute right-0 top-full mt-2 w-24 bg-white border border-gray-100 shadow-xl rounded-lg py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 text-center font-bold">
          <li><a href={getLangLink('tr')} aria-label="Türkçe Dilini Seç" class={`block px-4 py-2 hover:bg-gray-50 ${currentLang === 'tr' ? 'text-klinik-turuncu' : 'text-gray-600'}`}>TR</a></li>
          <li><a href={getLangLink('en')} aria-label="Switch to English" class={`block px-4 py-2 hover:bg-gray-50 ${currentLang === 'en' ? 'text-klinik-turuncu' : 'text-gray-600'}`}>EN</a></li>
          <li><a href={getLangLink('de')} aria-label="Auf Deutsch wechseln" class={`block px-4 py-2 hover:bg-gray-50 ${currentLang === 'de' ? 'text-klinik-turuncu' : 'text-gray-600'}`}>DE</a></li>
          <li><a href={getLangLink('bg')} aria-label="Превключване на български" class={`block px-4 py-2 hover:bg-gray-50 ${currentLang === 'bg' ? 'text-klinik-turuncu' : 'text-gray-600'}`}>BG</a></li>
        </ul>
      </div>

      <div class="hidden lg:block flex-shrink-0">
        <a href="tel:+902124000013" aria-label="Bizi Arayın" class="bg-klinik-koyu text-white px-3 xl:px-6 py-2 xl:py-3 rounded-full font-bold hover:bg-klinik-turuncu hover:shadow-lg transition-all duration-300 flex items-center gap-2 text-xs xl:text-base">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 xl:h-5 xl:w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" /></svg>
          <span class="hidden xl:inline">+90 212 400 00 13</span>
        </a>
      </div>
      
      <button id="mobile-menu-btn" aria-label="Mobil Menüyü Aç" class="lg:hidden text-klinik-koyu p-2 focus:outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7 md:w-8 md:h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
      </button>
    </div>
